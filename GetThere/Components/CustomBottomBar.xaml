<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="GetThere.Components.CustomBottomBar"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Name="this">

    <Grid
        x:Name="MainGrid"
        Margin="40,0,0,30"
        ColumnDefinitions="Auto,300,Auto"
        HorizontalOptions="Center"
        VerticalOptions="End"
        WidthRequest="460">

        <!--  ── LOGOUT CIRCLE (Left) ──  -->
        <Border
            Grid.Column="0"
            Margin="0,0,15,0"
            BackgroundColor="{AppThemeBinding Light=#F0FFFFFF,
                                              Dark=#C0121212}"
            HeightRequest="60"
            Stroke="{AppThemeBinding Light=#20000000,
                                     Dark=#20FFFFFF}"
            StrokeThickness="1"
            VerticalOptions="Center"
            WidthRequest="60">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30" />
            </Border.StrokeShape>
            <Image
                HeightRequest="26"
                Source="icon_logout.svg"
                WidthRequest="26">
                <Image.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="Gray" />
                </Image.Behaviors>
            </Image>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnConfirmLogoutClicked" />
            </Border.GestureRecognizers>
        </Border>

        <!--  ── MAIN BOTTOM BAR (Center) ──  -->
        <Border
            Grid.Column="1"
            BackgroundColor="{AppThemeBinding Light=#F0FFFFFF,
                                              Dark=#C0121212}"
            HeightRequest="80"
            Stroke="{AppThemeBinding Light=#20000000,
                                     Dark=#20FFFFFF}"
            StrokeThickness="1"
            WidthRequest="300">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="40" />
            </Border.StrokeShape>

            <Grid Padding="5" ColumnDefinitions="*,*,*">
                <!--  Profile Tab  -->
                <ContentView x:Name="ProfileTabContainer" Grid.Column="0">
                    <Image
                        Aspect="AspectFit"
                        HeightRequest="32"
                        Source="icon_profile.svg"
                        WidthRequest="32">
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior x:Name="ProfileTint" TintColor="Gray" />
                        </Image.Behaviors>
                    </Image>
                    <ContentView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped" />
                    </ContentView.GestureRecognizers>
                </ContentView>

                <!--  Map Tab  -->
                <ContentView Grid.Column="1">
                    <Image
                        Aspect="AspectFit"
                        HeightRequest="32"
                        Source="icon_location_pin.svg"
                        WidthRequest="32">
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior x:Name="MapTint" TintColor="Gray" />
                        </Image.Behaviors>
                    </Image>
                    <ContentView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMapTapped" />
                    </ContentView.GestureRecognizers>
                </ContentView>

                <!--  Operators Tab  -->
                <ContentView Grid.Column="2">
                    <Image
                        x:Name="OperatorsIcon"
                        Aspect="AspectFit"
                        HeightRequest="38"
                        Source="tab_bus.png"
                        WidthRequest="38">
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior x:Name="OperatorsTint" TintColor="Gray" />
                        </Image.Behaviors>
                    </Image>
                    <ContentView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOperatorsTapped" />
                    </ContentView.GestureRecognizers>
                </ContentView>
            </Grid>
        </Border>

        <!--  Invisible Spacer to balance the Logout button (keeps bar perfectly centered)  -->
        <ContentView
            Grid.Column="2"
            Margin="20,0,0,0"
            WidthRequest="60" />
    </Grid>
</ContentView>
