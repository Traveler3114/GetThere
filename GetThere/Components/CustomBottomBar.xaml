<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="GetThere.Components.CustomBottomBar"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Name="this">

    <Grid
        x:Name="MainGrid"
        Margin="40,0,0,20"
        VerticalOptions="End"
        HorizontalOptions="Center"
        WidthRequest="460">

        <!--  ── SMALL ISLAND BUTTON (Collapsed State) ──  -->
        <Border
            x:Name="CollapsedIsland"
            Grid.Column="1"
            WidthRequest="44"
            HeightRequest="44"
            Margin="0,0,0,0"
            HorizontalOptions="Center"
            VerticalOptions="End"
            BackgroundColor="{AppThemeBinding Light=#F0FFFFFF, Dark=#C0121212}"
            StrokeThickness="1"
            Stroke="{AppThemeBinding Light=#20000000, Dark=#20FFFFFF}"
            IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow x:Name="IslandShadow" Brush="Gray" Offset="0,0" Radius="15" Opacity="0.5" />
            </Border.Shadow>
            <Image
                x:Name="IslandIcon"
                Source="icon_location_pin.svg"
                WidthRequest="24"
                HeightRequest="24"
                VerticalOptions="Center"
                HorizontalOptions="Center">
                <Image.Behaviors>
                    <toolkit:IconTintColorBehavior x:Name="IslandTint" TintColor="Gray" />
                </Image.Behaviors>
            </Image>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnExpandClicked" />
            </Border.GestureRecognizers>
        </Border>

        <Grid x:Name="ExpandedBar" Grid.ColumnSpan="3" ColumnDefinitions="Auto,300,Auto" HorizontalOptions="Center">


        <!--  ── LOGOUT CIRCLE (Left) ──  -->
        <Border
            Grid.Column="0"
            Margin="0,0,15,0"
            BackgroundColor="{AppThemeBinding Light=#F0FFFFFF,
                                              Dark=#C0121212}"
            HeightRequest="44"
            Stroke="{AppThemeBinding Light=#20000000,
                                     Dark=#20FFFFFF}"
            StrokeThickness="1"
            VerticalOptions="Center"
            WidthRequest="44">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <Image
                HeightRequest="22"
                Source="icon_logout.svg"
                WidthRequest="22">
                <Image.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="Gray" />
                </Image.Behaviors>
            </Image>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnConfirmLogoutClicked" />
            </Border.GestureRecognizers>
        </Border>

        <!--  ── MAIN BOTTOM BAR (Center) ──  -->
        <Border
            Grid.Column="1"
            BackgroundColor="{AppThemeBinding Light=#F0FFFFFF,
                                              Dark=#C0121212}"
            HeightRequest="60"
            Stroke="{AppThemeBinding Light=#20000000,
                                     Dark=#20FFFFFF}"
            StrokeThickness="1"
            WidthRequest="300">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30" />
            </Border.StrokeShape>

            <Grid Padding="5" ColumnDefinitions="*,*,*">
                <!--  Profile Tab  -->
                <ContentView x:Name="ProfileTabContainer" Grid.Column="0">
                    <Image
                        Aspect="AspectFit"
                        HeightRequest="26"
                        Source="icon_profile.svg"
                        WidthRequest="26">
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior x:Name="ProfileTint" TintColor="Gray" />
                        </Image.Behaviors>
                    </Image>
                    <ContentView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped" />
                    </ContentView.GestureRecognizers>
                </ContentView>

                <!--  Map Tab  -->
                <ContentView Grid.Column="1">
                    <Image
                        Aspect="AspectFit"
                        HeightRequest="26"
                        Source="icon_location_pin.svg"
                        WidthRequest="26">
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior x:Name="MapTint" TintColor="Gray" />
                        </Image.Behaviors>
                    </Image>
                    <ContentView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMapTapped" />
                    </ContentView.GestureRecognizers>
                </ContentView>

                <!--  Operators Tab  -->
                <ContentView Grid.Column="2">
                    <Image
                        x:Name="OperatorsIcon"
                        Aspect="AspectFit"
                        HeightRequest="30"
                        Source="tab_bus.png"
                        WidthRequest="30">
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior x:Name="OperatorsTint" TintColor="Gray" />
                        </Image.Behaviors>
                    </Image>
                    <ContentView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOperatorsTapped" />
                    </ContentView.GestureRecognizers>
                </ContentView>
            </Grid>
        </Border>

        <!--  Invisible Spacer to balance the Logout button (keeps bar perfectly centered)  -->
            <ContentView
                Grid.Column="2"
                Margin="15,0,0,0"
                WidthRequest="44" />
        </Grid>
    </Grid>
</ContentView>
