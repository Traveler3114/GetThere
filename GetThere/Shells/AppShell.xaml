<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GetThere.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:GetThere.Pages"
    Title="GetThere"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">




    <FlyoutItem FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent
            x:Name="ProfileTab"
            Title="Profile"
            ContentTemplate="{DataTemplate pages:ProfilePage}"
            Icon="icon_profile.svg"
            Route="profile" />
        <ShellContent
            Title="Map"
            ContentTemplate="{DataTemplate pages:MapPage}"
            Icon="icon_location_pin.svg"
            Route="map" />
        <ShellContent
            Title="Operators"
            ContentTemplate="{DataTemplate pages:OperatorsPage}"
            Icon="icon_operators.svg"
            Route="operators" />
    </FlyoutItem>

</Shell>



