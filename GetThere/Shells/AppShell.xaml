<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GetThere.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:GetThere.Pages"
    xmlns:local="clr-namespace:GetThere"
    Title="GetThere"
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarForegroundColor="#059669"
    Shell.TabBarTitleColor="#059669"
    Shell.TabBarUnselectedColor="#9CA3AF">

    <TabBar>
        <ShellContent 
            Title="Profile" 
            Icon="profile.svg" 
            ContentTemplate="{DataTemplate pages:ProfilePage}" 
            Route="profile" />
        
        <ShellContent 
            Title="Map" 
            Icon="map.svg" 
            ContentTemplate="{DataTemplate pages:MapPage}" 
            Route="map" />
        
        <ShellContent 
            Title="Shop" 
            Icon="shop_bag.svg" 
            ContentTemplate="{DataTemplate pages:ShopPage}" 
            Route="shop" />
        
        <ShellContent 
            Title="Tickets" 
            Icon="ticket.svg" 
            ContentTemplate="{DataTemplate pages:TicketsPage}" 
            Route="tickets" />
        
        <ShellContent 
            Title="Settings" 
            Icon="settings.svg" 
            ContentTemplate="{DataTemplate pages:SettingsPage}" 
            Route="settings" />
    </TabBar>

</Shell>
