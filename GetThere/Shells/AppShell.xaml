<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GetThere.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:GetThere.Pages"
    xmlns:local="clr-namespace:GetThere"
    Title="GetThere"
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
    Shell.TabBarForegroundColor="#059669"
    Shell.TabBarTitleColor="#059669"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#9CA3AF, Dark=#94A3B8}">

    <TabBar>
        <ShellContent 
            Title="Profile" 
            Icon="{AppThemeBinding Light=profile.png, Dark=profile_white.png}" 
            ContentTemplate="{DataTemplate pages:ProfilePage}" 
            Route="profile" />
        
        <ShellContent 
            Title="Map" 
            Icon="{AppThemeBinding Light=map.png, Dark=map_white.png}" 
            ContentTemplate="{DataTemplate pages:MapPage}" 
            Route="map" />
        
        <ShellContent 
            Title="Shop" 
            Icon="{AppThemeBinding Light=shop_bag.png, Dark=shop_bag_white.png}" 
            ContentTemplate="{DataTemplate pages:ShopPage}" 
            Route="shop" />
        
        <ShellContent 
            Title="Tickets" 
            Icon="{AppThemeBinding Light=ticket.png, Dark=ticket_white.png}" 
            ContentTemplate="{DataTemplate pages:TicketsPage}" 
            Route="tickets" />
    </TabBar>

</Shell>
