<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GetThere.Pages.OperatorsPage"
             Title="Operators">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <SearchBar Grid.Row="0" x:Name="SearchBar" Placeholder="Search..." Margin="12,8" TextChanged="SearchBar_TextChanged" />
        <HorizontalStackLayout Grid.Row="1" Margin="12,8" Spacing="8">
            <Button x:Name="AllBtn" Text="All" Clicked="Filter_Clicked" BackgroundColor="#4CAF50" TextColor="White" />
            <Button x:Name="InstalledBtn" Text="Installed" Clicked="Filter_Clicked" />
            <Button x:Name="NotInstalledBtn" Text="Not Installed" Clicked="Filter_Clicked" />
        </HorizontalStackLayout>
        <CollectionView Grid.Row="2" x:Name="OperatorList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="12,4" Padding="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                <Label Text="{Binding City}" FontSize="13" TextColor="Gray" />
                                <Label Text="{Binding Country}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="{Binding IsInstalled, Converter={StaticResource InstallBtnTextConverter}}"
                                    BackgroundColor="{Binding IsInstalled, Converter={StaticResource InstallBtnColorConverter}}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    Clicked="InstallRemove_Clicked"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <ActivityIndicator Grid.RowSpan="4"
                           x:Name="BusyIndicator"
                           IsRunning="False"
                           IsVisible="False"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>