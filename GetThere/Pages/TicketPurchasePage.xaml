<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.TicketPurchasePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
    xmlns:components="clr-namespace:GetThere.Components"
    BackgroundColor="#F8F9FA"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="250,*">
        <components:AnimatedBackground Grid.RowSpan="2" />
        <Border Grid.Row="0" StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Offset="0" Color="#4E85F2" />
                    <GradientStop Offset="1" Color="#512BD4" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Padding="24,48,24,32" RowDefinitions="Auto,*,Auto">
                <ImageButton
                    HorizontalOptions="Start"
                    VerticalOptions="Start"
                    BackgroundColor="Transparent"
                    Clicked="OnBackClicked"
                    Source="arrow_left.svg"
                    HeightRequest="32"
                    Padding="0"
                    WidthRequest="32">
                    <ImageButton.Shadow>
                        <Shadow Brush="Black" Opacity="0.35" Offset="0,4" Radius="6" />
                    </ImageButton.Shadow>
                </ImageButton>

                <VerticalStackLayout x:Name="PageHeaderStack" Grid.Row="1" Spacing="4" VerticalOptions="Center">
                    <Label
                        x:Name="PageTitleLabel"
                        FontAttributes="Bold"
                        FontSize="32"
                        HorizontalTextAlignment="Center"
                        Text="Buy Tickets"
                        TextColor="White" />
                    <Label
                        x:Name="PageSubtitleLabel"
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        Text="Choose a ticket for this operator"
                        TextColor="#E5E7EB" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,-28,0,0" HorizontalOptions="Center">
        <Border x:Name="PurchaseSurface" BackgroundColor="White" StrokeThickness="0" HorizontalOptions="Fill">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30,30,0,0" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.12" Offset="0,4" Radius="8" />
            </Border.Shadow>

            <ScrollView x:Name="MainScrollView" Padding="0,0,0,100" VerticalScrollBarVisibility="Never" Scrolled="OnMainScrollViewScrolled">
                <VerticalStackLayout Padding="24,14,24,24" Spacing="14">
                    <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="#E0E0E0" HorizontalOptions="Center" />

                    <Border x:Name="MockBanner" Padding="14,10" BackgroundColor="#FFF3CD" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label FontAttributes="Bold"
                               FontSize="13"
                               HorizontalTextAlignment="Center"
                               Text="⚠ MOCK TICKETS — NOT VALID FOR TRAVEL ⚠"
                               TextColor="#9A6B00" />
                    </Border>

                    <ActivityIndicator
                        x:Name="BusyIndicator"
                        HeightRequest="40"
                        IsRunning="False"
                        IsVisible="False"
                        Color="#009688" />

                    <VerticalStackLayout x:Name="OptionsContainer" Spacing="18" />

                    <VerticalStackLayout x:Name="EmptyState" IsVisible="False" Margin="0,24,0,0">
                        <Label
                            FontSize="15"
                            HorizontalOptions="Center"
                            Text="No ticket options available."
                            TextColor="Gray" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <!--  ── PREMIUM CUSTOM SCROLLBAR THUMB ──  -->
        <Border x:Name="CustomScrollThumb" 
                WidthRequest="4" 
                HeightRequest="40" 
                BackgroundColor="#CBD5E1" 
                HorizontalOptions="End" 
                VerticalOptions="Start"
                Margin="0,40,4,0" 
                IsVisible="False"
                ZIndex="1000">
            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="2" /></Border.StrokeShape>
        </Border>

        </Grid>
    </Grid>
</ContentPage>
