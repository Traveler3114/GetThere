<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.MockTicketConfirmationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    BackgroundColor="#F8F9FA"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <components:AnimatedBackground Grid.RowSpan="2" />

        <!--  Header  -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="24,48,24,0" ColumnSpacing="12">
            <ImageButton
                Grid.Column="0"
                BackgroundColor="Transparent"
                Clicked="OnDoneClicked"
                Source="icon_close.svg"
                HeightRequest="24"
                WidthRequest="24" />
            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="22"
                Text="Ticket Confirmed"
                TextColor="Black"
                VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="24,16,24,100">
            <VerticalStackLayout x:Name="ConfirmationContent" Spacing="16" HorizontalOptions="Center">

                <!--  Mock disclaimer banner  -->
                <Border
                    Padding="14,10"
                    BackgroundColor="#F8D7DA"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.1" Radius="12" Offset="0,6" />
                    </Border.Shadow>
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        HorizontalTextAlignment="Center"
                        Text="⛔  MOCK TICKET — NOT VALID FOR TRAVEL  ⛔"
                        TextColor="#842029" />
                </Border>

                <!--  Ticket card  -->
                <Border
                    Padding="24"
                    BackgroundColor="White"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.12" Radius="15" Offset="0,8" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">

                        <!--  Operator name  -->
                        <Label
                            x:Name="OperatorLabel"
                            FontAttributes="Bold"
                            FontSize="22"
                            HorizontalTextAlignment="Center"
                            TextColor="Black" />

                        <!--  Ticket name  -->
                        <Label
                            x:Name="TicketNameLabel"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            TextColor="#8E8E93" />

                        <!--  QR placeholder  -->
                        <Border
                            Margin="20,8"
                            Padding="16"
                            BackgroundColor="#F8F9FA"
                            HorizontalOptions="Center"
                            Stroke="#EBEBEC"
                            StrokeThickness="1"
                            WidthRequest="200">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,4" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    HorizontalTextAlignment="Center"
                                    Text="QR CODE (MOCK)"
                                    TextColor="Gray" />
                                <BoxView
                                    BackgroundColor="White"
                                    HeightRequest="140"
                                    HorizontalOptions="Fill"
                                    CornerRadius="8" />
                                <Label
                                    x:Name="TicketIdLabel"
                                    FontSize="10"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="CharacterWrap"
                                    TextColor="#A0A0A0" />
                            </VerticalStackLayout>
                        </Border>

                        <!--  Validity info  -->
                        <Grid
                            ColumnDefinitions="*,*"
                            ColumnSpacing="12"
                            Padding="0,4">
                            <Border
                                Grid.Column="0"
                                Padding="12"
                                BackgroundColor="#F4F5F7"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,4" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="2">
                                    <Label FontSize="11" Text="VALID FROM" TextColor="Gray" />
                                    <Label
                                        x:Name="ValidFromLabel"
                                        FontAttributes="Bold"
                                        FontSize="13"
                                        TextColor="Black" />
                                </VerticalStackLayout>
                            </Border>
                            <Border
                                Grid.Column="1"
                                Padding="12"
                                BackgroundColor="#F4F5F7"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,4" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="2">
                                    <Label FontSize="11" Text="VALID UNTIL" TextColor="Gray" />
                                    <Label
                                        x:Name="ValidUntilLabel"
                                        FontAttributes="Bold"
                                        FontSize="13"
                                        TextColor="Black" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!--  Price  -->
                        <Label
                            x:Name="PriceLabel"
                            FontAttributes="Bold"
                            FontSize="28"
                            HorizontalTextAlignment="Center"
                            TextColor="Black" />

                    </VerticalStackLayout>
                </Border>

                <!--  Done button  -->
                <Button
                    Clicked="OnDoneClicked"
                    CornerRadius="18"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="56"
                    Text="Done"
                    BackgroundColor="#009688"
                    TextColor="White">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Radius="10" Offset="0,4" />
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
