<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.MockTicketConfirmationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#120D14}">

    <Grid RowDefinitions="Auto,*">

        <components:AnimatedBackground Grid.RowSpan="2" />

        <!--  Header  -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="16,18,16,0" ColumnSpacing="12">
            <Button
                Grid.Column="0"
                BackgroundColor="Transparent"
                Clicked="OnDoneClicked"
                FontSize="20"
                HeightRequest="40"
                Text="✕"
                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                WidthRequest="40" />
            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="24"
                Text="Ticket Confirmed"
                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="16,12,16,100">
            <VerticalStackLayout Spacing="16">

                <!--  Mock disclaimer banner  -->
                <Border
                    Padding="14,10"
                    BackgroundColor="#F8D7DA"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        Text="⛔  MOCK TICKET — NOT VALID FOR TRAVEL  ⛔"
                        TextColor="#842029" />
                </Border>

                <!--  Ticket card  -->
                <Border
                    Padding="24"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.08" Radius="12" Offset="0,4" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">

                        <!--  Operator name  -->
                        <Label
                            x:Name="OperatorLabel"
                            FontAttributes="Bold"
                            FontSize="22"
                            HorizontalTextAlignment="Center"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <!--  Ticket name  -->
                        <Label
                            x:Name="TicketNameLabel"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            TextColor="Gray" />

                        <!--  QR placeholder  -->
                        <Border
                            Margin="20,8"
                            Padding="16"
                            BackgroundColor="{AppThemeBinding Light=#F6F6F6, Dark=#2C2C2E}"
                            HorizontalOptions="Center"
                            StrokeThickness="0"
                            WidthRequest="200">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    HorizontalTextAlignment="Center"
                                    Text="QR CODE (MOCK)"
                                    TextColor="Gray" />
                                <BoxView
                                    BackgroundColor="{AppThemeBinding Light=#111, Dark=#EEE}"
                                    HeightRequest="140"
                                    HorizontalOptions="Fill"
                                    CornerRadius="6" />
                                <Label
                                    x:Name="TicketIdLabel"
                                    FontSize="10"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="CharacterWrap"
                                    TextColor="Gray" />
                            </VerticalStackLayout>
                        </Border>

                        <!--  Validity info  -->
                        <Grid
                            ColumnDefinitions="*,*"
                            ColumnSpacing="12"
                            Padding="0,4">
                            <Border
                                Grid.Column="0"
                                Padding="12"
                                BackgroundColor="{AppThemeBinding Light=#F0F0F5, Dark=#2C2C2E}"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label FontSize="11" Text="VALID FROM" TextColor="Gray" />
                                    <Label
                                        x:Name="ValidFromLabel"
                                        FontAttributes="Bold"
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border
                                Grid.Column="1"
                                Padding="12"
                                BackgroundColor="{AppThemeBinding Light=#F0F0F5, Dark=#2C2C2E}"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label FontSize="11" Text="VALID UNTIL" TextColor="Gray" />
                                    <Label
                                        x:Name="ValidUntilLabel"
                                        FontAttributes="Bold"
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!--  Price  -->
                        <Label
                            x:Name="PriceLabel"
                            FontAttributes="Bold"
                            FontSize="20"
                            HorizontalTextAlignment="Center"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    </VerticalStackLayout>
                </Border>

                <!--  Done button  -->
                <Button
                    Clicked="OnDoneClicked"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="52"
                    Text="Done"
                    BackgroundColor="#1264AB"
                    TextColor="White" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
