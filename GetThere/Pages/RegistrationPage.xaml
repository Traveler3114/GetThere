<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:GetThere.Components"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:localization="clr-namespace:GetThere.Localization"
             xmlns:vm="clr-namespace:GetThere.ViewModels"
             xmlns:helpers="clr-namespace:GetThere.Helpers"
             x:Class="GetThere.Pages.RegistrationPage"
             x:DataType="vm:RegistrationViewModel"
             Title="Registration"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#0F172A}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
    </ContentPage.Resources>

    <Grid>
        <components:AnimatedBackground />

        <ScrollView>
            <Border x:Name="RegistrationCard" Margin="24,80,24,24" Padding="30,24"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                    StrokeThickness="0" VerticalOptions="Start" MaximumWidthRequest="400"
                    HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.15" Radius="15" Offset="0,10" />
                </Border.Shadow>
                <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>

                <VerticalStackLayout Spacing="16" MaximumWidthRequest="400">
                    <Label Text="{localization:Translate Register_Title}" FontSize="28"
                           FontAttributes="Bold" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label Text="{localization:Translate Register_Subtitle}" FontSize="14"
                           HorizontalOptions="Center" Margin="0,0,0,10"
                           TextColor="{AppThemeBinding Light=Gray, Dark=#9CA3AF}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="{localization:Translate Register_FullNameLabel}" FontAttributes="Bold"
                               FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Border Stroke="{AppThemeBinding Light=#EBEBEC, Dark=#374151}" StrokeThickness="1"
                                Padding="12,0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}"
                                HeightRequest="50">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <Entry Text="{Binding FullName}"
                                   Placeholder="{localization:Translate Register_FullNamePlaceholder}"
                                   PlaceholderColor="{AppThemeBinding Light=#A0A0A0, Dark=#94A3B8}"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                   HeightRequest="50" VerticalOptions="Center" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="{localization:Translate Register_EmailLabel}" FontAttributes="Bold"
                               FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Border Stroke="{AppThemeBinding Light=#EBEBEC, Dark=#374151}" StrokeThickness="1"
                                Padding="12,0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}"
                                HeightRequest="50">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <Entry Text="{Binding Email}"
                                   Placeholder="{localization:Translate Register_EmailPlaceholder}"
                                   PlaceholderColor="{AppThemeBinding Light=#A0A0A0, Dark=#94A3B8}"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                   Keyboard="Email" HeightRequest="50" VerticalOptions="Center" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="{localization:Translate Register_PasswordLabel}" FontAttributes="Bold"
                               FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Border Stroke="{AppThemeBinding Light=#EBEBEC, Dark=#374151}" StrokeThickness="1"
                                Padding="12,0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}"
                                HeightRequest="50">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="*, auto">
                                <Entry Text="{Binding Password}"
                                       IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                                       Placeholder="{localization:Translate Register_PasswordPlaceholder}"
                                       PlaceholderColor="{AppThemeBinding Light=#A0A0A0, Dark=#94A3B8}"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       HeightRequest="50" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding PasswordToggleText}"
                                       TextColor="{AppThemeBinding Light=#A0A0A0, Dark=#94A3B8}"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding TogglePasswordCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="{localization:Translate Register_ConfirmPasswordLabel}" FontAttributes="Bold"
                               FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Border Stroke="{AppThemeBinding Light=#EBEBEC, Dark=#374151}" StrokeThickness="1"
                                Padding="12,0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}"
                                HeightRequest="50">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="*, auto">
                                <Entry Text="{Binding ConfirmPassword}"
                                       IsPassword="{Binding IsConfirmPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                                       Placeholder="{localization:Translate Register_ConfirmPasswordPlaceholder}"
                                       PlaceholderColor="{AppThemeBinding Light=#A0A0A0, Dark=#94A3B8}"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       HeightRequest="50" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding ConfirmToggleText}"
                                       TextColor="{AppThemeBinding Light=#A0A0A0, Dark=#94A3B8}"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleConfirmCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <Label Text="{Binding ErrorText}" TextColor="{AppThemeBinding Light=Red, Dark=#FCA5A5}"
                           FontSize="12" HorizontalOptions="Center"
                           IsVisible="{Binding HasError}" />

                    <Button Text="{localization:Translate Register_Button}"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="#512BD4" TextColor="White" CornerRadius="26"
                            HeightRequest="52" FontAttributes="Bold" Margin="0,8,0,0">
                        <Button.Shadow>
                            <Shadow Brush="Black" Opacity="0.25" Offset="4,4" Radius="4" />
                        </Button.Shadow>
                    </Button>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="{localization:Translate Register_AlreadyHaveAccount}"
                               FontSize="14" TextColor="{AppThemeBinding Light=Gray, Dark=#9CA3AF}"
                               VerticalOptions="Center" />
                        <Label Text="{localization:Translate Register_SignIn}"
                               TextColor="{AppThemeBinding Light=#009688, Dark=#5EEAD4}"
                               FontAttributes="Bold" FontSize="14" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>
