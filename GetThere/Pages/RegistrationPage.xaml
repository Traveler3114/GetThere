<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:GetThere.Components"
             x:Class="GetThere.Pages.RegistrationPage"
             Title="Create account"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}">

    <Grid RowDefinitions="*">
        <!-- Animated background (behind everything) -->
        <components:AnimatedBackground x:Name="AnimatedBg" Grid.Row="0" />

        <!-- Main content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout x:Name="ContentLayout" Padding="24" Spacing="12">
                <VerticalStackLayout.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnPanUpdate" />
                </VerticalStackLayout.GestureRecognizers>

            <!-- ── HEADER ── -->
            <VerticalStackLayout Spacing="6" Margin="0,48,0,24">
                <Label Text="Create your account"
                       FontSize="28" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                       HorizontalOptions="Center" />
                <Label Text="It only takes a minute"
                       FontSize="14" TextColor="Gray"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- ── PERSONAL DETAILS ── -->
            <Label Text="PERSONAL DETAILS"
                   FontSize="11" TextColor="Gray" FontAttributes="Bold"
                   Margin="4,0,0,0" CharacterSpacing="1" />

            <Entry x:Name="FullNameEntry"
                   Placeholder="Full name"
                   Keyboard="Text"
                   BackgroundColor="Transparent"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                   PlaceholderColor="Gray" />

            <Entry x:Name="EmailEntry"
                   Placeholder="Email address"
                   Keyboard="Email"
                   BackgroundColor="Transparent"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                   PlaceholderColor="Gray" />

            <Entry x:Name="PhoneEntry"
                   Placeholder="Phone (optional)"
                   Keyboard="Telephone"
                   BackgroundColor="Transparent"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                   PlaceholderColor="Gray" />

            <!-- ── PASSWORD ── -->
            <Label Text="PASSWORD"
                   FontSize="11" TextColor="Gray" FontAttributes="Bold"
                   Margin="4,12,0,0" CharacterSpacing="1" />

            <!-- Password with eye toggle -->
            <Grid>
                <Entry x:Name="PasswordEntry"
                       Placeholder="Password (min. 8 characters)"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                       PlaceholderColor="Gray"
                       HorizontalOptions="Fill" />
                <Label x:Name="TogglePasswordBtn"
                       Text="Show"
                       FontSize="13"
                       TextColor="Gray"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       Padding="10,0"
                       Margin="0,0,5,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="TogglePassword_Clicked" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- Confirm password with eye toggle -->
            <Grid>
                <Entry x:Name="ConfirmPasswordEntry"
                       Placeholder="Confirm password"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                       PlaceholderColor="Gray"
                       HorizontalOptions="Fill" />
                <Label x:Name="ToggleConfirmPasswordBtn"
                       Text="Show"
                       FontSize="13"
                       TextColor="Gray"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       Padding="10,0"
                       Margin="0,0,5,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="ToggleConfirmPassword_Clicked" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- ── ERROR ── -->
            <Label x:Name="ErrorLabel"
                   TextColor="Red" FontSize="13"
                   IsVisible="False"
                   HorizontalOptions="Center" Margin="0,4,0,0" />

            <!-- ── REGISTER BUTTON ── -->
            <Button x:Name="RegisterButton"
                    Text="Create account"
                    Clicked="RegisterButton_Clicked"
                    CornerRadius="12" FontAttributes="Bold"
                    HeightRequest="52" Margin="0,8,0,0" />

            <!-- ── BUSY ── -->
            <ActivityIndicator x:Name="BusyIndicator"
                               IsRunning="False" IsVisible="False"
                               Color="#4CAF50"
                               HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── CUSTOM FOOTER NAVIGATION (Absolute Bottom) ── -->
        <HorizontalStackLayout Grid.Row="0"
                               HorizontalOptions="Center" 
                               VerticalOptions="End"
                               Spacing="40" 
                               Padding="0,0,0,20">
            <Label Text="Login"
                   FontSize="16"
                   TextColor="Gray"
                   FontAttributes="Bold">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LoginButton_Clicked" />
                </Label.GestureRecognizers>
            </Label>
            <Label Text="Register"
                   FontSize="16"
                   TextColor="#FF00FF"
                   FontAttributes="Bold">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="RegisterButton_Clicked" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>
    </Grid>

</ContentPage>