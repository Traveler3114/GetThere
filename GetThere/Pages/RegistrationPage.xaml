<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.RegistrationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    xmlns:localization="clr-namespace:GetThere.Localization"
    Title="{localization:Translate Register_Title}"
    Shell.NavBarIsVisible="False">

    <Grid>
        <components:AnimatedBackground />

        <ScrollView Padding="24,34,24,28">
            <VerticalStackLayout
                Spacing="18"
                HorizontalOptions="Center"
                MaximumWidthRequest="460">

                <Grid ColumnDefinitions="44,*">
                    <Border
                        WidthRequest="44"
                        HeightRequest="44"
                        BackgroundColor="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppSurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource AppBorderLight}, Dark={StaticResource AppBorderDark}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22" />
                        </Border.StrokeShape>
                        <ImageButton
                            Source="arrow_left.png"
                            BackgroundColor="Transparent"
                            Padding="12"
                            Clicked="LoginButton_Clicked" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="3" Margin="14,0,0,0" VerticalOptions="Center">
                        <Label
                            Text="{localization:Translate Register_Title}"
                            Style="{StaticResource PageTitleLabel}" />
                        <Label
                            Text="{localization:Translate Register_Subtitle}"
                            Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                </Grid>

                <Border
                    x:Name="RegistrationCard"
                    Style="{StaticResource AppCard}"
                    Padding="22">
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="7">
                            <Label
                                Text="{localization:Translate Register_FullNameLabel}"
                                Style="{StaticResource SectionTitleLabel}"
                                FontSize="14" />
                            <Border Style="{StaticResource InputFrame}">
                                <Entry
                                    x:Name="FullNameEntry"
                                    Placeholder="{localization:Translate Register_FullNamePlaceholder}"
                                    HeightRequest="50" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label
                                Text="{localization:Translate Register_EmailLabel}"
                                Style="{StaticResource SectionTitleLabel}"
                                FontSize="14" />
                            <Border Style="{StaticResource InputFrame}">
                                <Entry
                                    x:Name="EmailEntry"
                                    Placeholder="{localization:Translate Register_EmailPlaceholder}"
                                    Keyboard="Email"
                                    HeightRequest="50" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label
                                Text="{localization:Translate Register_PasswordLabel}"
                                Style="{StaticResource SectionTitleLabel}"
                                FontSize="14" />
                            <Border Style="{StaticResource InputFrame}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Entry
                                        x:Name="PasswordEntry"
                                        Placeholder="{localization:Translate Register_PasswordPlaceholder}"
                                        IsPassword="True"
                                        HeightRequest="50" />
                                    <Label
                                        x:Name="TogglePassBtn"
                                        Grid.Column="1"
                                        Text="{localization:Translate Login_ShowPassword}"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource AppPrimary}"
                                        VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="TogglePass_Tapped" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label
                                Text="{localization:Translate Register_ConfirmPasswordLabel}"
                                Style="{StaticResource SectionTitleLabel}"
                                FontSize="14" />
                            <Border Style="{StaticResource InputFrame}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Entry
                                        x:Name="ConfirmPasswordEntry"
                                        Placeholder="{localization:Translate Register_ConfirmPasswordPlaceholder}"
                                        IsPassword="True"
                                        HeightRequest="50" />
                                    <Label
                                        x:Name="ToggleConfirmBtn"
                                        Grid.Column="1"
                                        Text="{localization:Translate Login_ShowPassword}"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource AppPrimary}"
                                        VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="ToggleConfirm_Tapped" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <Label
                            x:Name="ErrorLabel"
                            TextColor="{StaticResource AppDanger}"
                            FontSize="12"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            IsVisible="False" />

                        <Grid Margin="0,8,0,0">
                            <Button
                                x:Name="RegisterButton"
                                Text="{localization:Translate Register_Button}"
                                Clicked="RegisterButton_Clicked"
                                Style="{StaticResource PrimaryButton}" />
                            <ActivityIndicator
                                x:Name="BusyIndicator"
                                IsRunning="False"
                                IsVisible="False"
                                Color="{StaticResource AppPrimary}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Grid>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Label
                                Text="{localization:Translate Register_AlreadyHaveAccount}"
                                Style="{StaticResource MutedLabel}" />
                            <Label
                                Text="{localization:Translate Register_SignIn}"
                                TextColor="{StaticResource AppPrimary}"
                                FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="LoginButton_Tapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
