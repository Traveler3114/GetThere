<?xml version="1.0" encoding="utf-8" ?>
    <ContentPage
        x:Class="GetThere.Pages.ProfilePage"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:components="clr-namespace:GetThere.Components"
        xmlns:helpers="clr-namespace:GetThere.Helpers"
        xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
        Title="Profile"
    BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <helpers:StatusToColorConverter x:Key="StatusToColorConverter" />
        <helpers:TxTypeToIconConverter x:Key="TxTypeToIconConverter" />
        <helpers:TxTypeToAmountColorConverter x:Key="TxTypeToAmountColorConverter" />

        <DataTemplate x:Key="HistoryTemplate">
            <Grid
                Padding="0,10"
                ColumnDefinitions="48,*,Auto"
                ColumnSpacing="12">
                <Border
                    Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light=#ECECEC,
                                                      Dark=#2C2C2E}"
                    HeightRequest="48"
                    StrokeThickness="0"
                    WidthRequest="48">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Label
                        FontSize="22"
                        HorizontalOptions="Center"
                        Text="{Binding Type, Converter={StaticResource TxTypeToIconConverter}}"
                        VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="15"
                        LineBreakMode="TailTruncation"
                        MaxLines="1"
                        Text="{Binding Description}"
                        TextColor="Black" />
                    <Label
                        FontSize="12"
                        Text="{Binding Timestamp, StringFormat='{0:dd MMM HH:mm}'}"
                        TextColor="#4B5563" />
                </VerticalStackLayout>
                <HorizontalStackLayout
                    Grid.Column="2"
                    Spacing="0"
                    HorizontalOptions="End"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        Text="{Binding FormattedAmount}"
                        TextColor="{Binding Type, Converter={StaticResource TxTypeToAmountColorConverter}}" />
                </HorizontalStackLayout>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TicketTemplate">
            <Grid
                Padding="0,10"
                ColumnDefinitions="48,*,Auto"
                ColumnSpacing="12">
                <Border
                    Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light=#ECECEC,
                                                      Dark=#2C2C2E}"
                    HeightRequest="48"
                    StrokeThickness="0"
                    WidthRequest="48">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Image
                        HeightRequest="24"
                        HorizontalOptions="Center"
                        Source="tab_tram.png"
                        VerticalOptions="Center"
                        WidthRequest="24">
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                        </Image.Behaviors>
                    </Image>
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="15"
                        Text="{Binding Name}"
                        TextColor="{AppThemeBinding Light=Black,
                                                    Dark=White}" />
                    <Label
                        FontSize="12"
                        Text="{Binding Status}"
                        TextColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                </VerticalStackLayout>
                <HorizontalStackLayout Grid.Column="2" VerticalOptions="Center">
                    <Label
                        FontSize="20"
                        Text="›"
                        TextColor="#C7C7CC" />
                </HorizontalStackLayout>
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid x:Name="RootLayout" RowDefinitions="*,Auto">
        <components:AnimatedBackground Grid.RowSpan="2" />
        <Grid Grid.Row="0" RowDefinitions="Auto,*">
            <ScrollView Grid.Row="0">
                <VerticalStackLayout Padding="0,0,0,100" Spacing="14">

                    <!--  ── MAIN PASS CARD (Apple Style) ──  -->
                    <Grid Margin="16,20,16,10" HorizontalOptions="Center">
                    <Border
                        x:Name="MainCard"
                        HeightRequest="210"
                        HorizontalOptions="Fill"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24" />
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0.1" Color="#A2AAEE" />
                                <GradientStop Offset="0.4" Color="#E1BEE7" />
                                <GradientStop Offset="0.7" Color="#FFB2A0" />
                                <GradientStop Offset="1.0" Color="#FFE082" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Opacity="0.16"
                                Radius="8"
                                Offset="4,4" />
                        </Border.Shadow>

                        <Grid Padding="20">
                            <Border WidthRequest="60"
                                    HeightRequest="60"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Start"
                                    BackgroundColor="#35208F"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="30" />
                                </Border.StrokeShape>
                            </Border>

                            <!--  CENTER BALANCE SECTION (NO PLUS BUTTON HERE)  -->
                            <VerticalStackLayout
                                HorizontalOptions="Center"
                                Spacing="0"
                                VerticalOptions="Center">
                                <Label
                                    x:Name="BalanceLabelOnCard"
                                    FontAttributes="Bold"
                                    FontSize="44"
                                    HorizontalTextAlignment="Center"
                                    Text="€0.00"
                                    TextColor="#2E2055" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="2" VerticalOptions="End">
                                <Label
                                    x:Name="NameLabelOnCard"
                                    FontAttributes="Bold"
                                    FontSize="18"
                                    Text="User Name"
                                    TextColor="#7A7A7A" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                    </Grid>

                    <!--  ── PLUS BUTTON BELOW CARD ──  -->
                    <Button
                        x:Name="TopUpButton"
                        Margin="0,-48,0,0"
                        Padding="0"
                        Background="{x:Null}"
                        BackgroundColor="White"
                        Clicked="OnTopUpClicked"
                        CornerRadius="28"
                        FontAttributes="Bold"
                        FontSize="28"
                        HeightRequest="56"
                        HorizontalOptions="Center"
                        Style="{x:Null}"
                        Text="+"
                        TextColor="Black"
                        WidthRequest="56"
                        ZIndex="1">
                        <Button.Shadow>
                            <Shadow
                                Brush="Black"
                                Opacity="0.16"
                                Radius="8"
                                Offset="4,4" />
                        </Button.Shadow>
                    </Button>

                    <VerticalStackLayout Margin="0,4,0,0" Spacing="6" HorizontalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="Center"
                            Text="History"
                            TextColor="Black" />
                        <BoxView
                            WidthRequest="70"
                            HeightRequest="3"
                            CornerRadius="2"
                            HorizontalOptions="Center"
                            BackgroundColor="#D1D1D6" />
                    </VerticalStackLayout>

                    <!--  ── LIST SECTION ──  -->
                    <Grid Margin="16,2,16,0" HorizontalOptions="Center">
                    <Border
                        x:Name="HistoryContainer"
                        Padding="15"
                        HorizontalOptions="Fill"
                        BackgroundColor="White"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Opacity="0.16"
                                Radius="8"
                                Offset="4,4" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="10">
                            <!--  Loaders  -->
                            <ActivityIndicator
                                x:Name="BusyLoader"
                                HeightRequest="40"
                                IsRunning="False"
                                IsVisible="False"
                                Color="#4CAF50" />

                            <!--  List Content  -->
                            <CollectionView
                                x:Name="MainCollection"
                                ItemTemplate="{StaticResource HistoryTemplate}"
                                SelectionMode="None" />

                            <Label
                                x:Name="NoItemsLabel"
                                Margin="0,30"
                                HorizontalOptions="Center"
                                IsVisible="False"
                                Text="No items found."
                                TextColor="Gray" />
                        </VerticalStackLayout>
                    </Border>
                    </Grid>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!--  ── GUEST OVERLAY ──  -->
        <Grid
            x:Name="GuestOverlay"
            BackgroundColor="{AppThemeBinding Light=#E6FFFFFF,
                                              Dark=#E6000000}"
            InputTransparent="False"
            IsVisible="False"
            ZIndex="2000">
            <VerticalStackLayout
                HorizontalOptions="Center"
                Spacing="20"
                VerticalOptions="Center">
                <Label
                    FontAttributes="Bold"
                    FontSize="26"
                    HorizontalOptions="Center"
                    Text="Guest Mode"
                    TextColor="{AppThemeBinding Light=Black,
                                                Dark=White}" />
                <Label
                    FontSize="16"
                    HorizontalOptions="Center"
                    Text="Please log in or register to access your profile."
                    TextColor="Gray" />
                <Button
                    Margin="0,15,0,0"
                    Padding="30,0"
                    Clicked="OnLoginRegisterClicked"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="Login / Register" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
