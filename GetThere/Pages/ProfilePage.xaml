<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    xmlns:helpers="clr-namespace:GetThere.Helpers"
    xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
    Title="Profile"
    BackgroundColor="#F3F4F6"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:TxTypeToAmountColorConverter x:Key="AmountColorConverter" />
        <helpers:TxTypeToIconConverter x:Key="TxTypeToIconConverter" />

        <DataTemplate x:Key="HistoryTemplate">
            <Border Margin="0,0,0,8" BackgroundColor="White" StrokeThickness="0" Padding="10,8">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Opacity="0.08" Radius="4" Offset="0,2" /></Border.Shadow>
                
                <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="10">
                    <!-- Icon -->
                    <Border Grid.Column="0" WidthRequest="36" HeightRequest="36" BackgroundColor="#F3F4F6" StrokeThickness="0">
                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <Label Text="{Binding Type, Converter={StaticResource TxTypeToIconConverter}}" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <!-- Info -->
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                        <Label Text="{Binding Description}" FontSize="14" FontAttributes="Bold" TextColor="#2E2055" LineBreakMode="TailTruncation" />
                        <Label Text="{Binding Timestamp, StringFormat='{0:dd MMM HH:mm}'}" FontSize="11" TextColor="Gray" />
                    </VerticalStackLayout>

                    <!-- Amount -->
                    <Label Grid.Column="2" 
                           Text="{Binding FormattedAmount}" 
                           TextColor="{Binding Type, Converter={StaticResource AmountColorConverter}}" 
                           FontAttributes="Bold" 
                           FontSize="14" 
                           VerticalOptions="Center" />
                </Grid>
            </Border>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid x:Name="RootLayout">
        <components:AnimatedBackground />
        
        <Grid RowDefinitions="Auto, Auto, *">
            
            <!-- 1. USER IDENTITY HEADER (ALIGNED WITH CONTENT) -->
            <Grid x:Name="UserHeader" Grid.Row="0" MaximumWidthRequest="600" HorizontalOptions="Center" Padding="24,15,24,0" ColumnDefinitions="Auto, *">
                <Border x:Name="UserAvatarBorder" WidthRequest="60" HeightRequest="60" StrokeThickness="3" Stroke="#512BD4">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                    <Image Source="profile.png" Margin="10" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAvatarClicked" />
                    </Border.GestureRecognizers>
                </Border>
                <VerticalStackLayout x:Name="UserInfoStack" Grid.Column="1" Margin="16,0,0,0" VerticalOptions="Center">
                    <Label x:Name="UserDisplayNameLabel" Text="Luka S." FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <Label Text="● VERIFIED" FontSize="11" FontAttributes="Bold" TextColor="#10B981" />
                </VerticalStackLayout>
            </Grid>

            <!-- 2. SEGMENTED CONTROL -->
            <Grid x:Name="TabSwitcherContainer" Grid.Row="1" Margin="24,5,24,10" HeightRequest="50" MaximumWidthRequest="400">
                <Border BackgroundColor="#E2E8F0" StrokeThickness="0">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="27" /></Border.StrokeShape>
                    <Grid x:Name="TabGrid" ColumnDefinitions="*, *">
                        <!-- Active Background Shadow (Ready for Translation animation) -->
                        <Border x:Name="TabIndicator" 
                                Grid.Column="0" 
                                Margin="4" 
                                BackgroundColor="White" 
                                StrokeThickness="0"
                                ZIndex="1">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="23" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Opacity="0.12" Radius="6" Offset="0,2" /></Border.Shadow>
                        </Border>

                        <Button Grid.Column="0" Text="Wallet" BackgroundColor="Transparent" Clicked="OnWalletTabClicked" x:Name="WalletTabBtn" TextColor="#512BD4" FontAttributes="Bold" ZIndex="2" />
                        <Button Grid.Column="1" Text="Account" BackgroundColor="Transparent" Clicked="OnAccountTabClicked" x:Name="AccountTabBtn" TextColor="#64748B" FontAttributes="Bold" ZIndex="2" />
                    </Grid>
                </Border>
            </Grid>

            <!-- 3. MAIN CONTENT AREA -->
            <Grid Grid.Row="2">
                
                <!-- ── WALLET TAB VIEW ── -->
                <Grid x:Name="WalletTabView" RowDefinitions="Auto, *" IsVisible="True">
                    <!-- Balance Card -->
                    <Grid x:Name="BalanceCardGrid" Grid.Row="0" Margin="16,5,16,10" HorizontalOptions="Center">
                        <Border x:Name="BalanceCard" WidthRequest="360" HeightRequest="180" HorizontalOptions="Center" StrokeThickness="0">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#4E85F2" />
                                    <GradientStop Offset="1" Color="#512BD4" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Shadow><Shadow Brush="Black" Opacity="0.22" Radius="12" Offset="0,6" /></Border.Shadow>

                            <Grid Padding="24">
                                <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label Text="CURRENT BALANCE" FontSize="10" FontAttributes="Bold" TextColor="White" Opacity="0.7" HorizontalOptions="Center" />
                                    
                                    <Grid ColumnSpacing="15" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="42" />
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" x:Name="BalanceLabelOnCard" FontAttributes="Bold" MinimumWidthRequest="140" HorizontalTextAlignment="Center" FontSize="38" Text="€0.00" TextColor="White" VerticalOptions="Center" />
                                        
                                        <ImageButton Grid.Column="1" x:Name="BalanceVisibilityButton"
                                                     Source="eye.png"
                                                     BackgroundColor="Transparent"
                                                     Padding="8"
                                                     Clicked="OnHideBalanceClicked"
                                                     VerticalOptions="Center"
                                                     WidthRequest="42"
                                                     HeightRequest="42"
                                                     Aspect="AspectFit" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Button x:Name="TopUpButton" VerticalOptions="End" TranslationY="28" BackgroundColor="White" Clicked="OnTopUpClicked" CornerRadius="28" FontAttributes="Bold" FontSize="28" HeightRequest="56" HorizontalOptions="Center" Text="+" TextColor="Black" WidthRequest="56" ZIndex="10">
                            <Button.Shadow><Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" /></Button.Shadow>
                        </Button>
                    </Grid>

                    <!-- History Surface -->
                    <Grid x:Name="HistoryContainer" Grid.Row="1" RowDefinitions="Auto, *" Margin="0,25,0,0">
                        <Label x:Name="RecentActivityLabel" Grid.Row="0" Text="Recent Activity" FontSize="16" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center" Margin="0,5,0,10" />
                        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" HorizontalOptions="Center" MaximumWidthRequest="1200" VerticalOptions="Fill">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="36,36,0,0" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Opacity="0.05" Radius="20" Offset="0,-10" /></Border.Shadow>
                            
                            <!-- WRAPPER GRID TO HOLD SCROLLVIEW + THUMB -->
                            <Grid>
                                <ScrollView x:Name="WalletScrollView" VerticalScrollBarVisibility="Never" Scrolled="OnMainScrollViewScrolled">
                                    <VerticalStackLayout Padding="24,20,24,120">
                                        <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="#E5E7EB" HorizontalOptions="Center" Margin="0,12,0,12" />
                                        <StackLayout x:Name="HistoryRows" BindableLayout.ItemTemplate="{StaticResource HistoryTemplate}" Spacing="0" />
                                        <Label x:Name="NoItemsLabel" Margin="0,40" HorizontalOptions="Center" IsVisible="False" Text="No transactions yet" FontSize="16" TextColor="Gray" />
                                    </VerticalStackLayout>
                                </ScrollView>

                                <!-- INDICATOR INSIDE THE BORDER -->
                                <Border x:Name="CustomScrollThumb" 
                                        WidthRequest="4" 
                                        HeightRequest="40" 
                                        BackgroundColor="#CBD5E1" 
                                        HorizontalOptions="End" 
                                        VerticalOptions="Start"
                                        Margin="0,20,6,0" 
                                        IsVisible="False"
                                        ZIndex="1000">
                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="2" /></Border.StrokeShape>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ── ACCOUNT TAB VIEW ── -->
                <ScrollView x:Name="AccountTabView" IsVisible="False" Padding="20,10,20,120" VerticalScrollBarVisibility="Never" Scrolled="OnMainScrollViewScrolled">
                    <VerticalStackLayout Spacing="16" MaximumWidthRequest="600">
                        <!-- Personal Info Card -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Personal Information" FontSize="16" FontAttributes="Bold" TextColor="Black" />
                            <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <Border.Shadow><Shadow Brush="Black" Opacity="0.08" Radius="8" Offset="0,4" /></Border.Shadow>
                                <VerticalStackLayout Spacing="15">
                                    <VerticalStackLayout>
                                        <Label Text="FULL NAME" FontSize="10" TextColor="#94A3B8" FontAttributes="Bold" />
                                        <Label x:Name="AccountFullNameLabel" Text="-" FontSize="15" FontAttributes="Bold" TextColor="Black" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout>
                                        <Label Text="EMAIL ADDRESS" FontSize="10" TextColor="#94A3B8" FontAttributes="Bold" />
                                        <Label x:Name="AccountEmailLabel" Text="-" FontSize="15" FontAttributes="Bold" TextColor="Black" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Settings Card -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Settings &amp; Security" FontSize="16" FontAttributes="Bold" TextColor="Black" />
                            <Border BackgroundColor="White" StrokeThickness="0" Padding="0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <Border.Shadow><Shadow Brush="Black" Opacity="0.08" Radius="8" Offset="0,4" /></Border.Shadow>
                                <VerticalStackLayout>
                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="16,12">
                                        <Image Source="profile.png" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Account Privacy" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.png" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnPrivacyClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="20,0" />

                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="16,12">
                                        <Image Source="ticket.png" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Payment Methods" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.png" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnPaymentMethodsClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="20,0" />

                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="16,12">
                                        <Image Source="map.png" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Language &amp; Region" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.png" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnLanguageRegionClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="20,0" />

                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="16,12">
                                        <Image Source="settings.png" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Change Password" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.png" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnChangePasswordClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Support & About -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Support &amp; More" FontSize="17" FontAttributes="Bold" TextColor="Black" />
                            <Border BackgroundColor="White" StrokeThickness="0" Padding="0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                <Border.Shadow><Shadow Brush="Black" Opacity="0.12" Radius="10" Offset="0,4" /></Border.Shadow>
                                <VerticalStackLayout>
                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                                        <Image Source="settings.png" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Help Center" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.png" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnHelpCenterClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="20,0" />

                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                                        <Image Source="profile.png" WidthRequest="20" HeightRequest="20" Opacity="0.6" />
                                        <Label Grid.Column="1" Text="About GetThere" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.png" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnAboutClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="20,0" />
                                    
                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="20" Tapped="OnLogoutClicked">
                                        <Image Source="log_off.png" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Sign Out" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="#991B1B" FontAttributes="Bold" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnLogoutClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- PREMIUM SKELETON LOADING -->
                <Grid x:Name="PremiumLoadingState" IsVisible="False" VerticalOptions="FillAndExpand">
                    <Image Source="loading_profile.svg" Aspect="AspectFill" InputTransparent="True" Opacity="0.8" />
                    
                    <Grid IsClippedToBounds="True" InputTransparent="True">
                        <BoxView x:Name="ShimmerBox" WidthRequest="250" HorizontalOptions="Start" TranslationX="-400" Opacity="0.3">
                            <BoxView.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0" />
                                    <GradientStop Color="#FFFFFF" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </BoxView.Background>
                            <BoxView.Rotation>20</BoxView.Rotation>
                        </BoxView>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>


        <!--  ── SUB-SETTINGS OVERLAY (SHOP STYLE) ──  -->
        <Grid x:Name="SubSettingsView" BackgroundColor="#F3F4F6" IsVisible="False" ZIndex="1500">
            <Grid RowDefinitions="Auto, *">
                <!-- Header (Shop Style) -->
                <Grid Grid.Row="0" x:Name="SubSettingsHeader" Padding="24,48,24,10" ColumnDefinitions="48, *, 48" MaximumWidthRequest="600" HorizontalOptions="Fill" ZIndex="2">
                    <!-- Back Arrow (Corrected Coordinates) -->
                    <Grid Grid.Column="0" WidthRequest="44" HeightRequest="44" HorizontalOptions="Start" VerticalOptions="Center">
                        <shapes:Path Data="M19,5L9,12l10,7 M9,12h14" 
                                     Stroke="Black" 
                                     StrokeThickness="2.5" 
                                     StrokeLineCap="Round" 
                                     StrokeLineJoin="Round"
                                     HorizontalOptions="Center" 
                                     VerticalOptions="Center"
                                     WidthRequest="24" 
                                     HeightRequest="24" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackFromSubSettings" />
                        </Grid.GestureRecognizers>
                    </Grid>
                    <Label x:Name="SubSettingsTitle" Grid.Column="1" HorizontalOptions="Center" Text="Settings" FontSize="20" FontAttributes="Bold" TextColor="Black" VerticalOptions="Center" />
                </Grid>

                <!-- Content Card (Shop Style) -->
                <ScrollView Grid.Row="1" Padding="0,20,0,0">
                    <VerticalStackLayout Spacing="0">
                        <Border BackgroundColor="White" StrokeThickness="0" Margin="0" MaximumWidthRequest="1200" HorizontalOptions="Fill">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="40,40,0,0" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Opacity="0.05" Radius="20" Offset="0,-10" /></Border.Shadow>
                            
                            <VerticalStackLayout Padding="24,20,24,100" Spacing="20">
                                <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="#E5E7EB" HorizontalOptions="Center" />
                                
                                <ActivityIndicator x:Name="SubSettingsLoader" IsRunning="False" IsVisible="False" Color="#512BD4" />
                                
                                <VerticalStackLayout x:Name="SubSettingsContent" Spacing="0" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Grid>

        <!--  ── GUEST OVERLAY ──  -->
        <Grid x:Name="GuestOverlay" BackgroundColor="{AppThemeBinding Light=#E6FFFFFF, Dark=#E6000000}" InputTransparent="False" IsVisible="False" ZIndex="2000">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="20" VerticalOptions="Center">
                <Label FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" Text="Guest Mode" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Label FontSize="16" HorizontalOptions="Center" HorizontalTextAlignment="Center" Text="Sign in to see your balance and history." TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />
                <Button Margin="0,10,0,0" Padding="30,0" Clicked="OnLoginRegisterClicked" CornerRadius="12" FontAttributes="Bold" HeightRequest="50" Text="Login / Register" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
