<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    xmlns:helpers="clr-namespace:GetThere.Helpers"
    Title="Profile"
    BackgroundColor="#F3F4F6"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:TxTypeToAmountColorConverter x:Key="AmountColorConverter" />
        <helpers:TxTypeToIconConverter x:Key="TxTypeToIconConverter" />

        <DataTemplate x:Key="HistoryTemplate">
            <Grid Padding="0,12" ColumnDefinitions="Auto,*,Auto">
                <!--  Status Icon with Circle Background  -->
                <Border
                    Grid.Column="0"
                    WidthRequest="48"
                    HeightRequest="48"
                    Margin="0,0,16,0"
                    BackgroundColor="#FFFBEB"
                    StrokeThickness="0"
                    VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Label
                        FontSize="22"
                        HorizontalOptions="Center"
                        Text="{Binding Type, Converter={StaticResource TxTypeToIconConverter}}"
                        VerticalOptions="Center" />
                </Border>

                <!--  Details  -->
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        Text="{Binding Description}"
                        TextColor="Black" />
                    <Label
                        FontSize="13"
                        Text="{Binding Timestamp, StringFormat='{0:dd MMM HH:mm}'}"
                        TextColor="Gray" />
                </VerticalStackLayout>

                <!--  Amount  -->
                <HorizontalStackLayout Grid.Column="2" VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="17"
                        Text="{Binding FormattedAmount}"
                        TextColor="{Binding Type, Converter={StaticResource AmountColorConverter}}" />
                </HorizontalStackLayout>
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid x:Name="RootLayout">
        <components:AnimatedBackground />
        
        <Grid RowDefinitions="Auto, *">
            
            <!-- ── FIXED TOP SECTION (CARD) ── -->
            <VerticalStackLayout Grid.Row="0" Padding="0,20,0,10" Spacing="0" MaximumWidthRequest="1200" HorizontalOptions="Fill">
                
                <!--  Main Pass Card (Fixed width on desktop, responsive on mobile) -->
                <Grid Margin="16,20,16,10" MaximumWidthRequest="600" HorizontalOptions="Fill">
                    <Border
                        x:Name="MainCard"
                        HeightRequest="210"
                        HorizontalOptions="Fill"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24" />
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0.1" Color="#A2AAEE" />
                                <GradientStop Offset="0.4" Color="#E1BEE7" />
                                <GradientStop Offset="0.7" Color="#FFB2A0" />
                                <GradientStop Offset="1.0" Color="#FFE082" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" />
                        </Border.Shadow>

                        <Grid Padding="20">
                            <Border WidthRequest="60" HeightRequest="60" HorizontalOptions="Start" VerticalOptions="Start" BackgroundColor="#35208F" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                            </Border>

                            <Label x:Name="BalanceLabelOnCard" FontAttributes="Bold" FontSize="44" HorizontalOptions="Center" VerticalOptions="Center" Text="€0.00" TextColor="#2E2055" />

                            <Label x:Name="NameLabelOnCard" FontAttributes="Bold" FontSize="18" VerticalOptions="End" Text="User Name" TextColor="#7A7A7A" />
                        </Grid>
                    </Border>

                    <Button
                        x:Name="TopUpButton"
                        VerticalOptions="End"
                        Margin="0,0,0,-28"
                        Padding="0"
                        BackgroundColor="White"
                        Clicked="OnTopUpClicked"
                        CornerRadius="28"
                        FontAttributes="Bold"
                        FontSize="28"
                        HeightRequest="56"
                        HorizontalOptions="Center"
                        Text="+"
                        TextColor="Black"
                        WidthRequest="56"
                        ZIndex="1">
                        <Button.Shadow>
                            <Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" />
                        </Button.Shadow>
                    </Button>
                </Grid>

                <VerticalStackLayout Margin="0,35,0,10" Spacing="6" HorizontalOptions="Center">
                    <Label FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" Text="History" TextColor="Black" />
                    <BoxView WidthRequest="70" HeightRequest="3" CornerRadius="2" HorizontalOptions="Center" BackgroundColor="#D1D1D6" />
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- ── SCROLLABLE LIST SECTION (WHITE SURFACE) ── -->
            <Grid Grid.Row="1" Margin="0,5,0,0" HorizontalOptions="Fill">
                <Border x:Name="HistorySurface" Margin="0,0,0,0" BackgroundColor="White" StrokeThickness="0" HorizontalOptions="Center" MaximumWidthRequest="1200">
                    <Border.StrokeShape><RoundRectangle CornerRadius="40,40,0,0" /></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Opacity="0.05" Radius="20" Offset="0,-10" /></Border.Shadow>
                    
                    <ScrollView>
                        <VerticalStackLayout Padding="24,20,24,100" Spacing="10">
                            <ActivityIndicator x:Name="BusyLoader" HeightRequest="40" IsRunning="False" IsVisible="False" Color="#4CAF50" />

                            <VerticalStackLayout x:Name="HistoryRows" BindableLayout.ItemTemplate="{StaticResource HistoryTemplate}" />

                            <Label x:Name="NoItemsLabel" Margin="0,40" HorizontalOptions="Center" IsVisible="False" Text="No items found." FontSize="18" TextColor="Gray" />
                        </VerticalStackLayout>
                    </ScrollView>
                </Border>
            </Grid>

        </Grid>

        <!--  ── GUEST OVERLAY ──  -->
        <Grid x:Name="GuestOverlay" BackgroundColor="{AppThemeBinding Light=#E6FFFFFF, Dark=#E6000000}" InputTransparent="False" IsVisible="False" ZIndex="2000">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="20" VerticalOptions="Center">
                <Label FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" Text="Guest Mode" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Label FontSize="16" HorizontalOptions="Center" HorizontalTextAlignment="Center" Text="Sign in to see your balance and history." TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />
                <Button Margin="0,10,0,0" Padding="30,0" Clicked="OnLoginRegisterClicked" CornerRadius="12" FontAttributes="Bold" HeightRequest="50" Text="Login / Register" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
