<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    xmlns:helpers="clr-namespace:GetThere.Helpers"
    xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
    Title="Profile"
    BackgroundColor="#F3F4F6"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:TxTypeToAmountColorConverter x:Key="AmountColorConverter" />
        <helpers:TxTypeToIconConverter x:Key="TxTypeToIconConverter" />

        <DataTemplate x:Key="HistoryTemplate">
            <Border Margin="0,0,0,12" BackgroundColor="White" StrokeThickness="0" Padding="12">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Opacity="0.22" Radius="12" Offset="0,6" /></Border.Shadow>

                <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                    <!-- Icon -->
                    <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" BackgroundColor="#F3F4F6" StrokeThickness="0">
                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                        <Label Text="{Binding Type, Converter={StaticResource TxTypeToIconConverter}}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <!-- Info -->
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="{Binding Description}" FontSize="15" FontAttributes="Bold" TextColor="#2E2055" />
                        <Label Text="{Binding Timestamp, StringFormat='{0:dd MMM HH:mm}'}" FontSize="12" TextColor="Gray" />
                    </VerticalStackLayout>

                    <!-- Amount -->
                    <Label Grid.Column="2" 
                           Text="{Binding FormattedAmount}" 
                           TextColor="{Binding Type, Converter={StaticResource AmountColorConverter}}" 
                           FontAttributes="Bold" 
                           FontSize="15" 
                           VerticalOptions="Center" />
                </Grid>
            </Border>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid x:Name="RootLayout">
        <components:AnimatedBackground />
        
        <Grid RowDefinitions="Auto, Auto, *">
            
            <!-- 1. USER IDENTITY HEADER (ALIGNED WITH CONTENT) -->
            <Grid Grid.Row="0" MaximumWidthRequest="600" HorizontalOptions="Center" Padding="24,35,24,10" ColumnDefinitions="Auto, *">
                <Border WidthRequest="70" HeightRequest="70" StrokeThickness="3" Stroke="#512BD4">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="35" /></Border.StrokeShape>
                    <Image Source="profile.svg" Margin="12" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAvatarClicked" />
                    </Border.GestureRecognizers>
                </Border>
                <VerticalStackLayout Grid.Column="1" Margin="16,0,0,0" VerticalOptions="Center">
                    <Label x:Name="UserDisplayNameLabel" Text="Luka S." FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <Label Text="● VERIFIED" FontSize="11" FontAttributes="Bold" TextColor="#10B981" />
                </VerticalStackLayout>
            </Grid>

            <!-- 2. SEGMENTED CONTROL -->
            <Grid Grid.Row="1" Margin="24,10,24,15" HeightRequest="54" MaximumWidthRequest="400">
                <Border BackgroundColor="#E2E8F0" StrokeThickness="0">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="27" /></Border.StrokeShape>
                    <Grid x:Name="TabGrid" ColumnDefinitions="*, *">
                        <!-- Active Background Shadow (Ready for Translation animation) -->
                        <Border x:Name="TabIndicator" 
                                Grid.Column="0" 
                                Margin="4" 
                                BackgroundColor="White" 
                                StrokeThickness="0"
                                ZIndex="1">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="23" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Opacity="0.12" Radius="6" Offset="0,2" /></Border.Shadow>
                        </Border>

                        <Button Grid.Column="0" Text="Wallet" BackgroundColor="Transparent" Clicked="OnWalletTabClicked" x:Name="WalletTabBtn" TextColor="#512BD4" FontAttributes="Bold" ZIndex="2" />
                        <Button Grid.Column="1" Text="Account" BackgroundColor="Transparent" Clicked="OnAccountTabClicked" x:Name="AccountTabBtn" TextColor="#64748B" FontAttributes="Bold" ZIndex="2" />
                    </Grid>
                </Border>
            </Grid>

            <!-- 3. MAIN CONTENT AREA -->
            <Grid Grid.Row="2">
                
                <!-- ── WALLET TAB VIEW ── -->
                <VerticalStackLayout x:Name="WalletTabView" Spacing="0" IsVisible="True">
                    <!-- Balance Card -->
                    <Grid Margin="16,10,16,10" HorizontalOptions="Center">
                        <Border x:Name="MainCard" WidthRequest="360" HeightRequest="210" HorizontalOptions="Center" StrokeThickness="0">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#4E85F2" />
                                    <GradientStop Offset="1" Color="#512BD4" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Shadow><Shadow Brush="Black" Opacity="0.22" Radius="12" Offset="0,6" /></Border.Shadow>

                            <Grid Padding="24">
                                <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label Text="CURRENT BALANCE" FontSize="11" FontAttributes="Bold" TextColor="White" Opacity="0.7" HorizontalOptions="Center" />
                                    
                                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label x:Name="BalanceLabelOnCard" FontAttributes="Bold" FontSize="44" Text="€0.00" TextColor="White" VerticalOptions="Center" />
                                        
                                        <Button BackgroundColor="Transparent" Padding="8" Clicked="OnHideBalanceClicked" VerticalOptions="Center">
                                            <Button.Content>
                                                <Path x:Name="EyeIconPath" 
                                                      Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                                                      Fill="White"
                                                      WidthRequest="26"
                                                      HeightRequest="26" />
                                            </Button.Content>
                                        </Button>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Button x:Name="TopUpButton" VerticalOptions="End" TranslationY="28" BackgroundColor="White" Clicked="OnTopUpClicked" CornerRadius="28" FontAttributes="Bold" FontSize="28" HeightRequest="56" HorizontalOptions="Center" Text="+" TextColor="Black" WidthRequest="56" ZIndex="10">
                            <Button.Shadow><Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" /></Button.Shadow>
                        </Button>
                    </Grid>

                    <!-- History Surface -->
                    <Grid x:Name="HistoryContainer" RowDefinitions="Auto, *" Margin="0,40,0,0">
                        <Label Grid.Row="0" Text="Recent Activity" FontSize="17" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center" Margin="0,10,0,15" />
                        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" HorizontalOptions="Center" MaximumWidthRequest="1200" VerticalOptions="Fill">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="36,36,0,0" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Opacity="0.05" Radius="20" Offset="0,-10" /></Border.Shadow>
                            <ScrollView HeightRequest="450">
                                <VerticalStackLayout Padding="24,10,24,120">
                                    <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="#E5E7EB" HorizontalOptions="Center" Margin="0,12,0,12" />
                                    <StackLayout x:Name="HistoryRows" BindableLayout.ItemTemplate="{StaticResource HistoryTemplate}" Spacing="0" />
                                    <Label x:Name="NoItemsLabel" Margin="0,40" HorizontalOptions="Center" IsVisible="False" Text="No transactions yet" FontSize="16" TextColor="Gray" />
                                </VerticalStackLayout>
                            </ScrollView>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- ── ACCOUNT TAB VIEW ── -->
                <ScrollView x:Name="AccountTabView" IsVisible="False" Padding="24,10,24,120">
                    <VerticalStackLayout Spacing="24" MaximumWidthRequest="600">
                        <!-- Personal Info Card -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Personal Information" FontSize="17" FontAttributes="Bold" TextColor="Black" />
                            <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                <Border.Shadow><Shadow Brush="Black" Opacity="0.12" Radius="10" Offset="0,4" /></Border.Shadow>
                                <VerticalStackLayout Spacing="15">
                                    <VerticalStackLayout>
                                        <Label Text="FULL NAME" FontSize="10" TextColor="#94A3B8" FontAttributes="Bold" />
                                        <Label x:Name="AccountFullNameLabel" Text="-" FontSize="15" FontAttributes="Bold" TextColor="Black" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout>
                                        <Label Text="EMAIL ADDRESS" FontSize="10" TextColor="#94A3B8" FontAttributes="Bold" />
                                        <Label x:Name="AccountEmailLabel" Text="-" FontSize="15" FontAttributes="Bold" TextColor="Black" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Settings Card -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Settings &amp; Security" FontSize="17" FontAttributes="Bold" TextColor="Black" />
                            <Border BackgroundColor="White" StrokeThickness="0" Padding="0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                <Border.Shadow><Shadow Brush="Black" Opacity="0.12" Radius="10" Offset="0,4" /></Border.Shadow>
                                <VerticalStackLayout>
                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                                        <Image Source="profile.svg" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Account Privacy" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.svg" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnPrivacyClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="20,0" />

                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                                        <Image Source="ticket.svg" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Payment Methods" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.svg" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnPaymentMethodsClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="20,0" />

                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                                        <Image Source="map.svg" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Language &amp; Region" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.svg" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnLanguageRegionClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="20,0" />

                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                                        <Image Source="settings.svg" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Change Password" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.svg" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnChangePasswordClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Support & About -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Support &amp; More" FontSize="17" FontAttributes="Bold" TextColor="Black" />
                            <Border BackgroundColor="White" StrokeThickness="0" Padding="0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                <Border.Shadow><Shadow Brush="Black" Opacity="0.12" Radius="10" Offset="0,4" /></Border.Shadow>
                                <VerticalStackLayout>
                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                                        <Image Source="settings.svg" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Help Center" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.svg" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnHelpCenterClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="20,0" />

                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                                        <Image Source="profile.svg" WidthRequest="20" HeightRequest="20" Opacity="0.6" />
                                        <Label Grid.Column="1" Text="About GetThere" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="Black" />
                                        <Image Grid.Column="2" Source="arrow_right.svg" WidthRequest="12" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnAboutClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="20,0" />
                                    
                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="20" Tapped="OnLogoutClicked">
                                        <Image Source="log_off.svg" WidthRequest="20" HeightRequest="20" />
                                        <Label Grid.Column="1" Text="Sign Out" Margin="15,0" VerticalOptions="Center" FontSize="15" TextColor="#991B1B" FontAttributes="Bold" />
                                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnLogoutClicked" /></Grid.GestureRecognizers>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Full Page Loader -->
                <ActivityIndicator x:Name="BusyLoader" VerticalOptions="Center" HorizontalOptions="Center" HeightRequest="60" WidthRequest="60" IsRunning="False" IsVisible="False" Color="#512BD4" />
            </Grid>
        </Grid>

        <!--  ── SUB-SETTINGS OVERLAY (SHOP STYLE) ──  -->
        <Grid x:Name="SubSettingsView" BackgroundColor="#F3F4F6" IsVisible="False" ZIndex="1500">
            <Grid RowDefinitions="Auto, *">
                <!-- Header (Shop Style) -->
                <Grid Grid.Row="0" Padding="24,48,24,10" ColumnDefinitions="48, *, 48" MaximumWidthRequest="600" HorizontalOptions="Fill" ZIndex="2">
                    <Button Grid.Column="0" 
                            BackgroundColor="Transparent" 
                            Padding="0"
                            WidthRequest="40"
                            HeightRequest="40"
                            HorizontalOptions="Start"
                            Clicked="OnBackFromSubSettings">
                        <Button.Content>
                            <shapes:Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" 
                                  Fill="Black" 
                                  WidthRequest="24" 
                                  HeightRequest="24" 
                                  HorizontalOptions="Center" 
                                  VerticalOptions="Center" />
                        </Button.Content>
                    </Button>
                    <Label x:Name="SubSettingsTitle" Grid.Column="1" HorizontalOptions="Center" Text="Settings" FontSize="20" FontAttributes="Bold" TextColor="Black" VerticalOptions="Center" />
                </Grid>

                <!-- Content Card (Shop Style) -->
                <ScrollView Grid.Row="1" Padding="0,20,0,0">
                    <VerticalStackLayout Spacing="0">
                        <Border BackgroundColor="White" StrokeThickness="0" Margin="0" MaximumWidthRequest="1200" HorizontalOptions="Fill">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="40,40,0,0" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Opacity="0.05" Radius="20" Offset="0,-10" /></Border.Shadow>
                            
                            <VerticalStackLayout Padding="24,20,24,100" Spacing="20">
                                <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="#E5E7EB" HorizontalOptions="Center" />
                                
                                <ActivityIndicator x:Name="SubSettingsLoader" IsRunning="False" IsVisible="False" Color="#512BD4" />
                                
                                <VerticalStackLayout x:Name="SubSettingsContent" Spacing="0" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Grid>

        <!--  ── GUEST OVERLAY ──  -->
        <Grid x:Name="GuestOverlay" BackgroundColor="{AppThemeBinding Light=#E6FFFFFF, Dark=#E6000000}" InputTransparent="False" IsVisible="False" ZIndex="2000">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="20" VerticalOptions="Center">
                <Label FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" Text="Guest Mode" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Label FontSize="16" HorizontalOptions="Center" HorizontalTextAlignment="Center" Text="Sign in to see your balance and history." TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />
                <Button Margin="0,10,0,0" Padding="30,0" Clicked="OnLoginRegisterClicked" CornerRadius="12" FontAttributes="Bold" HeightRequest="50" Text="Login / Register" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
