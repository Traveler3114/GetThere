<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GetThere.Pages.ProfilePage"
             Title="Profile">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Avatar + Name + Email -->
            <Border StrokeShape="Ellipse"
                WidthRequest="80"
                HeightRequest="80"
                BackgroundColor="#5B4FCF"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Padding="0">
                        <Label x:Name="AvatarLabel"
                   Text="?"
                   FontSize="36"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            </Border>

            <Label x:Name="NameLabel"
                   Text="Loading..."
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label x:Name="EmailLabel"
                   Text=""
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalOptions="Center" />

            <!-- Wallet Balance Card -->
            <Border StrokeShape="RoundRectangle 16"
                BackgroundColor="#F3F0FF"
                Padding="20"
                Margin="0,10,0,0">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Wallet Balance"
                       FontSize="13"
                       TextColor="Gray" />
                            <Label x:Name="BalanceLabel"
                       Text="€ --"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#5B4FCF" />
                        </VerticalStackLayout>
            </Border>

            <!-- Top Up Button -->
            <Button x:Name="TopUpButton"
                    Text="Top Up Wallet"
                    BackgroundColor="#5B4FCF"
                    TextColor="White"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    Clicked="TopUpButton_Clicked" />

            <!-- Busy Indicator -->
            <ActivityIndicator x:Name="BusyIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="#5B4FCF"
                               HorizontalOptions="Center" />

            <!-- Error Label -->
            <Label x:Name="ErrorLabel"
                   Text=""
                   TextColor="Red"
                   IsVisible="False"
                   HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>