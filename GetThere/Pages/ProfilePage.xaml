<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:GetThere.Helpers"
             xmlns:components="clr-namespace:GetThere.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="GetThere.Pages.ProfilePage"
             Title="Profile"
             BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#000000}">

    <ContentPage.Resources>
        <helpers:StatusToColorConverter x:Key="StatusToColorConverter" />
        <helpers:TxTypeToIconConverter  x:Key="TxTypeToIconConverter" />

        <DataTemplate x:Key="TicketTemplate">
            <Border Margin="0,0,0,12" Padding="15" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" />
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Label Text="{Binding TicketType}" FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label Grid.Row="1" Text="{Binding ValidUntil, StringFormat='Valid until: {0:dd MMM yyyy}'}" FontSize="12" TextColor="Gray" />
                    
                    <Border Grid.Column="1" Grid.RowSpan="2" Padding="12,6" StrokeThickness="0" BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}" VerticalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <Label Text="{Binding Status}" FontSize="12" TextColor="White" FontAttributes="Bold" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="HistoryTemplate">
            <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="12" Padding="0,10">
                <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" BackgroundColor="{AppThemeBinding Light=#ECECEC, Dark=#2C2C2E}" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                    <Label Text="{Binding Type, Converter={StaticResource TxTypeToIconConverter}}" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="{Binding Description}" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" MaxLines="1" LineBreakMode="TailTruncation" />
                    <Label Text="{Binding Timestamp, StringFormat='{0:dddd}'}" FontSize="12" TextColor="Gray" />
                </VerticalStackLayout>
                <HorizontalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                    <Label Text="{Binding Amount, StringFormat='+€{0:F2}'}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label Text="›" FontSize="20" TextColor="#C7C7CC" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid RowDefinitions="*">
        <!-- ── DECORATIVE BACKGROUND CIRCLES ── -->
        <!-- Animated background (behind everything) -->
        <components:AnimatedBackground x:Name="AnimatedBg" Grid.Row="0" />

        <Grid RowDefinitions="Auto,*">


            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="0,0,0,100" Spacing="20">
                    
                    <!-- ── MAIN PASS CARD (Apple Style) ── -->
                    <Border Margin="16,5,16,10" HeightRequest="210" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#A2AAEE" Offset="0.1" />
                                <GradientStop Color="#E1BEE7" Offset="0.4" />
                                <GradientStop Color="#FFB2A0" Offset="0.7" />
                                <GradientStop Color="#FFE082" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,6" Radius="15" Opacity="0.1" />
                        </Border.Shadow>
                        
                        <Grid Padding="20">
                            <Label Text="Gt" FontSize="28" FontAttributes="Bold" TextColor="#40000000" HorizontalOptions="Start" VerticalOptions="Start" />
                            
                            <!-- CENTER BALANCE SECTION (NO PLUS BUTTON HERE) -->
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
                                <Label x:Name="BalanceLabelOnCard" Text="€0.00" FontSize="44" FontAttributes="Bold" TextColor="#D0000000" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout VerticalOptions="End" Spacing="2">
                                <Label x:Name="NameLabelOnCard" Text="User Name" FontSize="18" FontAttributes="Bold" TextColor="#50000000" />
                            </VerticalStackLayout>
                            
                            <Image Source="tab_tram.png" HorizontalOptions="End" VerticalOptions="Start" WidthRequest="40" Opacity="0.1" />
                        </Grid>
                    </Border>

                    <!-- ── PLUS BUTTON BELOW CARD ── -->
                    <Button Style="{x:Null}" Background="{x:Null}" Text="+" Clicked="OnTopUpClicked" 
                            BackgroundColor="#EBEBEC" 
                            TextColor="Black" 
                            FontSize="28" FontAttributes="Bold"
                            HeightRequest="56" WidthRequest="56"
                            CornerRadius="28" Padding="0" 
                            HorizontalOptions="Center" 
                            Margin="0,-48,0,0"
                            ZIndex="1">
                        <Button.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.1" />
                        </Button.Shadow>
                    </Button>

                    <!-- ── NAVIGATION TABS (Tickets / History) ── -->
                    <Grid ColumnDefinitions="*,*" Margin="16,10,16,0" Padding="3" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#1C1C1E}" HeightRequest="44">
                        <Grid.Clip>
                            <RoundRectangleGeometry CornerRadius="10" Rect="0,0,1000,44" />
                        </Grid.Clip>
                        <Button x:Name="TicketsTabBtn" Style="{x:Null}" Background="{x:Null}" Text="Tickets" Clicked="TicketsTab_Clicked" 
                                BackgroundColor="{AppThemeBinding Light=#EBEBEC, Dark=#2C2C2E}" 
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                                CornerRadius="8" FontAttributes="Bold" />
                        <Button x:Name="HistoryTabBtn" Style="{x:Null}" Background="{x:Null}" Text="History" Grid.Column="1" Clicked="HistoryTab_Clicked" 
                                BackgroundColor="Transparent" 
                                TextColor="{AppThemeBinding Light=Gray, Dark=#AAAAAA}" 
                                CornerRadius="8" FontAttributes="Bold" />
                    </Grid>

                    <!-- ── CONTENT SECTION ── -->
                    <Border Margin="16,10,16,0" Padding="15" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.05" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="10">
                            <!-- Filter Chips (only for Tickets) -->
                            <Grid x:Name="FilterRow" ColumnDefinitions="*,Auto" Margin="0,5,0,5">
                                <Label x:Name="CurrentFilterLabel" Text="All Active" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="Gray" />
                                <Button x:Name="FilterBtn" Style="{x:Null}" Background="{x:Null}" Grid.Column="1" Text="Filter ▾" Clicked="OnShowFilterOptions" 
                                        BackgroundColor="{AppThemeBinding Light=#EBEBEC, Dark=#2C2C2E}" 
                                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                        CornerRadius="16" HeightRequest="32" Padding="15,0" FontSize="12"
                                        BorderWidth="0" />
                            </Grid>
    
                            <!-- Loaders -->
                            <ActivityIndicator x:Name="BusyLoader" IsRunning="False" IsVisible="False" Color="#4CAF50" HeightRequest="40" />
    
                            <!-- List Content -->
                            <CollectionView x:Name="MainCollection" SelectionMode="None" />
                            
                            <Label x:Name="NoItemsLabel" Text="No items found." IsVisible="False" HorizontalOptions="Center" TextColor="Gray" Margin="0,30" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ── CUSTOM BOTTOM BAR ── -->
            <components:CustomBottomBar Grid.Row="1" VerticalOptions="End" />
        </Grid>

        <!-- ── CUSTOM FILTER BOTTOM SHEET (Moved to end) ── -->
        <Grid x:Name="FilterBottomSheet" Grid.RowSpan="2" IsVisible="False" Opacity="0" ZIndex="1000" VerticalOptions="Fill" HorizontalOptions="Fill">
            <!-- Background Overlay -->
            <BoxView BackgroundColor="Black" Opacity="0.5">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHideFilterBottomSheet" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Sheet Content container to help with clipping -->
            <Grid VerticalOptions="End" InputTransparent="False">
                <Border x:Name="FilterContent" Margin="10,0,10,20" Padding="0" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}" 
                        TranslationY="600" HeightRequest="320" WidthRequest="360" HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,10" Radius="30" Opacity="0.4" />
                    </Border.Shadow>
    
                    <VerticalStackLayout Padding="24" Spacing="12">
                        <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="Gray" Opacity="0.3" HorizontalOptions="Center" Margin="0,0,0,15" />
                        
                        <Label Text="Filter Tickets" HorizontalOptions="Center" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        
                        <Button Text="Active" Clicked="OnFilterOptionClicked" CommandParameter="Active" 
                                BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}" 
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                                CornerRadius="12" HeightRequest="50" FontSize="16" FontAttributes="Bold" />
                        
                        <Button Text="Expired" Clicked="OnFilterOptionClicked" CommandParameter="Expired" 
                                BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}" 
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                                CornerRadius="12" HeightRequest="50" FontSize="16" FontAttributes="Bold" />
                        
                        <Button Text="Used" Clicked="OnFilterOptionClicked" CommandParameter="Used" 
                                BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}" 
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                                CornerRadius="12" HeightRequest="50" FontSize="16" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
