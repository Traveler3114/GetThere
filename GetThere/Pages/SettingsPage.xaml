<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    Title="Settings"
    BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#0F172A}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <components:AnimatedBackground Grid.RowSpan="2" />

        <!--  Header  -->
        <Label
            Grid.Row="0"
            Margin="16,28,16,0"
            FontAttributes="Bold"
            FontSize="32"
            HorizontalTextAlignment="Center"
            Text="Settings"
            TextColor="{AppThemeBinding Light=Black, Dark=White}" />

        <ScrollView Grid.Row="1" Padding="16,16,16,100">
            <VerticalStackLayout x:Name="SettingsContent" Spacing="16" HorizontalOptions="Center">

                <!--  Country card  -->
                <Border
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">

                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Country"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <Label
                            FontSize="14"
                            Text="Select your country to see relevant operators and services."
                            TextColor="{AppThemeBinding Light=Gray, Dark=#9CA3AF}" />

                        <ActivityIndicator
                            x:Name="CountryLoader"
                            HeightRequest="30"
                            IsRunning="False"
                            IsVisible="False"
                            Color="{AppThemeBinding Light=#1264AB, Dark=#60A5FA}" />

                        <Picker
                            x:Name="CountryPicker"
                            Title="Select a country…"
                            TitleColor="{AppThemeBinding Light=Black, Dark=White}"
                            FontSize="16"
                            SelectedIndexChanged="OnCountrySelected"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F2937}" />

                        <Label
                            x:Name="CurrentCountryLabel"
                            FontSize="13"
                            IsVisible="False"
                            TextColor="{AppThemeBinding Light=#1264AB, Dark=#60A5FA}" />

                    </VerticalStackLayout>
                </Border>

                <!--  About card  -->
                <Border
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="About"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Label
                            FontSize="14"
                            Text="GetThere — public transport &amp; mobility app."
                            TextColor="{AppThemeBinding Light=Gray, Dark=#9CA3AF}" />
                        <Label
                            FontSize="12"
                            Text="Mock ticket purchases are for demonstration only and are not valid for travel."
                            TextColor="{AppThemeBinding Light=Gray, Dark=#9CA3AF}" />
                    </VerticalStackLayout>
                </Border>

                    <Button
                     x:Name="LogoutButton"
                    Text="Log out"
                    Clicked="OnLogoutClicked"
                    HorizontalOptions="Center"
                    Margin="0,28,0,0"
                    Padding="20,10"
                    FontAttributes="Bold"
                    FontSize="14"
                     TextColor="White"
                     BackgroundColor="{AppThemeBinding Light=#0EA5A4, Dark=#0F766E}"
                    CornerRadius="18"
                    WidthRequest="110">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" />
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
