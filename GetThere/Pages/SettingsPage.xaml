<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    xmlns:loc="clr-namespace:GetThere.Localization"
    Title="{loc:Translate Key=Settings_Title}"
    BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#0F172A}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <components:AnimatedBackground Grid.RowSpan="2" />

        <!--  Header  -->
        <Label
            Grid.Row="0"
            Margin="16,28,16,0"
            FontAttributes="Bold"
            FontSize="32"
            HorizontalTextAlignment="Center"
            Text="{loc:Translate Key=Settings_Title}"
            TextColor="{AppThemeBinding Light=Black, Dark=White}" />

        <ScrollView Grid.Row="1" Padding="16,16,16,100">
            <VerticalStackLayout x:Name="SettingsContent" Spacing="16" HorizontalOptions="Center">

                <!--  Country card  -->
                <Border
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">

                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{loc:Translate Key=Settings_Country}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <Label
                            FontSize="14"
                            Text="{loc:Translate Key=Settings_CountrySubtitle}"
                            TextColor="{AppThemeBinding Light=Gray, Dark=#9CA3AF}" />

                        <ActivityIndicator
                            x:Name="CountryLoader"
                            HeightRequest="30"
                            IsRunning="False"
                            IsVisible="False"
                            Color="{AppThemeBinding Light=#1264AB, Dark=#60A5FA}" />

                        <Picker
                            x:Name="CountryPicker"
                            Title="{loc:Translate Key=Settings_Country}"
                            TitleColor="{AppThemeBinding Light=Black, Dark=White}"
                            FontSize="16"
                            SelectedIndexChanged="OnCountrySelected"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F2937}" />

                        <Label
                            x:Name="CurrentCountryLabel"
                            FontSize="13"
                            IsVisible="False"
                            TextColor="{AppThemeBinding Light=#1264AB, Dark=#60A5FA}" />

                    </VerticalStackLayout>
                </Border>

                <!--  Language card  -->
                <Border
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">

                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{loc:Translate Key=Settings_Language}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <Label
                            FontSize="14"
                            Text="{loc:Translate Key=Settings_LanguageSubtitle}"
                            TextColor="{AppThemeBinding Light=Gray, Dark=#9CA3AF}" />

                        <Picker
                            x:Name="LanguagePicker"
                            FontSize="16"
                            SelectedIndexChanged="OnLanguageSelected"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1F2937}" />

                        <Label
                            x:Name="LanguageSavedLabel"
                            FontSize="13"
                            IsVisible="False"
                            TextColor="{AppThemeBinding Light=#1264AB, Dark=#60A5FA}" />

                    </VerticalStackLayout>
                </Border>

                <!--  About card  -->
                <Border
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{loc:Translate Key=Settings_About}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Label
                            FontSize="14"
                            Text="{loc:Translate Key=Settings_AboutText}"
                            TextColor="{AppThemeBinding Light=Gray, Dark=#9CA3AF}" />
                        <Label
                            FontSize="12"
                            Text="{loc:Translate Key=Settings_MockDisclaimer}"
                            TextColor="{AppThemeBinding Light=Gray, Dark=#9CA3AF}" />
                    </VerticalStackLayout>
                </Border>

                <Button
                    x:Name="LogoutButton"
                    Text="{loc:Translate Key=Settings_Logout}"
                    Clicked="OnLogoutClicked"
                    HorizontalOptions="Center"
                    Margin="0,28,0,0"
                    Padding="20,10"
                    FontAttributes="Bold"
                    FontSize="14"
                    TextColor="White"
                    BackgroundColor="{AppThemeBinding Light=#0EA5A4, Dark=#0F766E}"
                    CornerRadius="18"
                    WidthRequest="110">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.16" Radius="8" Offset="4,4" />
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
