<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    Title="Settings"
    BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#120D14}">

    <Grid RowDefinitions="Auto,*">

        <components:AnimatedBackground Grid.RowSpan="2" />

        <!--  Header  -->
        <Label
            Grid.Row="0"
            Margin="16,18,16,0"
            FontAttributes="Bold"
            FontSize="28"
            HorizontalTextAlignment="Center"
            Text="Settings"
            TextColor="{AppThemeBinding Light=Black, Dark=White}" />

        <ScrollView Grid.Row="1" Padding="16,16,16,100">
            <VerticalStackLayout Spacing="16">

                <!--  Country card  -->
                <Border
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.05" Radius="10" Offset="0,2" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">

                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Country"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <Label
                            FontSize="14"
                            Text="Select your country or choose All/None to show worldwide data."
                            TextColor="Gray" />

                        <ActivityIndicator
                            x:Name="CountryLoader"
                            HeightRequest="30"
                            IsRunning="False"
                            IsVisible="False"
                            Color="#1264AB" />

                        <Picker
                            x:Name="CountryPicker"
                            Title="Select a country…"
                            FontSize="16"
                            SelectedIndexChanged="OnCountrySelected"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <Label
                            x:Name="CurrentCountryLabel"
                            FontSize="13"
                            IsVisible="False"
                            TextColor="#1264AB" />

                    </VerticalStackLayout>
                </Border>

                <!--  About card  -->
                <Border
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.05" Radius="10" Offset="0,2" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="About"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Label
                            FontSize="14"
                            Text="GetThere — public transport &amp; mobility app."
                            TextColor="Gray" />
                        <Label
                            FontSize="12"
                            Text="Mock ticket purchases are for demonstration only and are not valid for travel."
                            TextColor="Gray" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
