<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:components="clr-namespace:GetThere.Components"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="GetThere.Pages.LoginPage"
             Title="Sign In"
             BackgroundColor="#F8F9FA"
             Shell.NavBarIsVisible="False">

    <Grid>
        <components:AnimatedBackground />
        
        <!--  ── HERO AREA (Fixed 420px height) ──  -->
        <Border VerticalOptions="Start" HeightRequest="420" StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Offset="0" Color="#4E85F2" />
                    <GradientStop Offset="1" Color="#512BD4" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.3" Offset="0,5" Radius="10" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="35" VerticalOptions="Start" Margin="0,85,0,0">
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Border WidthRequest="24" HeightRequest="24" BackgroundColor="#009688" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    </Border>
                    <Label Text="GetThere" FontSize="26" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                </HorizontalStackLayout>
                
                <Border WidthRequest="160" HeightRequest="160" BackgroundColor="#2C167A" HorizontalOptions="Center" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="80" /></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.3" Offset="3,3" Radius="10" />
                    </Border.Shadow>
                </Border>
            </VerticalStackLayout>
        </Border>

        <Grid Margin="0,350,0,10" HorizontalOptions="Center">
        <ScrollView VerticalOptions="Fill">
            <Border x:Name="LoginCard" Margin="1" Padding="30,15,30,30" BackgroundColor="White" StrokeThickness="0" VerticalOptions="Start">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.15" Offset="0,10" Radius="15" />
                </Border.Shadow>
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>

                <VerticalStackLayout Spacing="16">
                    <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="#E0E0E0" HorizontalOptions="Center" Margin="0,0,0,15" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Email" FontAttributes="Bold" FontSize="14" TextColor="Black" />
                        <Border Stroke="#EBEBEC" StrokeThickness="1" Padding="15,0" BackgroundColor="White" HeightRequest="50">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Entry x:Name="EmailEntry" Placeholder="Email" PlaceholderColor="#A0A0A0" TextColor="Black" Keyboard="Email" HeightRequest="50" VerticalOptions="Center" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Password" FontAttributes="Bold" FontSize="14" TextColor="Black" />
                        <Border Stroke="#EBEBEC" StrokeThickness="1" Padding="15,0" BackgroundColor="White" HeightRequest="50">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="*, auto">
                                <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" PlaceholderColor="#A0A0A0" TextColor="Black" HeightRequest="50" VerticalOptions="Center" />
                                <Label x:Name="TogglePasswordBtn" Grid.Column="1" Text="Show" TextColor="#A0A0A0" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="TogglePassword_Clicked" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <Label x:Name="ErrorLabel" TextColor="Red" FontSize="12" HorizontalOptions="Center" IsVisible="False" />

                    <Button x:Name="LoginButton" Text="Sign In" Clicked="LoginButton_Clicked" BackgroundColor="#009688" TextColor="White" CornerRadius="26" HeightRequest="52" FontAttributes="Bold" Margin="0,20,0,0">
                        <Button.Shadow>
                            <Shadow Brush="Black" Opacity="0.25" Offset="4,4" Radius="4" />
                        </Button.Shadow>
                    </Button>

                    <Label Text="Create Account" TextColor="#009688" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,5">
                        <Label.GestureRecognizers><TapGestureRecognizer Tapped="RegisterButton_Clicked" /></Label.GestureRecognizers>
                    </Label>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="20" Margin="0,15,0,0">
                        <Border WidthRequest="40" HeightRequest="40" Stroke="#EBEBEC" BackgroundColor="White">
                             <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                             <Label Text="G" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="Black" />
                        </Border>
                        <Border WidthRequest="40" HeightRequest="40" Stroke="#EBEBEC" BackgroundColor="White">
                             <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                             <Label Text="Ap" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="Black" />
                        </Border>
                    </HorizontalStackLayout>
                    <!-- PREMIUM LOADING STATE FOR LOGIN -->
                    <Grid x:Name="PremiumLoadingState" IsVisible="False" HorizontalOptions="Center" Margin="0,10">
                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="LoadingDotsLabel" Text="Signing In" FontSize="16" TextColor="#009688" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Border WidthRequest="140" HeightRequest="6" BackgroundColor="#F1F5F9" StrokeThickness="0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="3" /></Border.StrokeShape>
                                <Grid IsClippedToBounds="True">
                                    <BoxView x:Name="ShimmerBox" WidthRequest="60" HorizontalOptions="Start" TranslationX="-60">
                                        <BoxView.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="Transparent" Offset="0" />
                                                <GradientStop Color="#80FFFFFF" Offset="0.5" />
                                                <GradientStop Color="Transparent" Offset="1" />
                                            </LinearGradientBrush>
                                        </BoxView.Background>
                                    </BoxView>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
