<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:GetThere.Components"
             x:Class="GetThere.Pages.LoginPage"
             Title="Log in"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}">

    <Grid RowDefinitions="*">
        <!-- Animated background (behind everything) -->
        <components:AnimatedBackground x:Name="AnimatedBg" Grid.Row="0" />

        <!-- Main content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout x:Name="ContentLayout" Padding="24" Spacing="16">
                <VerticalStackLayout.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnPanUpdate" />
                </VerticalStackLayout.GestureRecognizers>

            <!-- ── HEADER ── -->
            <VerticalStackLayout Spacing="6" Margin="0,48,0,24">
                <Label Text="Welcome back"
                       FontSize="28" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                       HorizontalOptions="Center" />
                <Label Text="Log in to your account"
                       FontSize="14" TextColor="Gray"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- ── EMAIL ── -->
            <Entry x:Name="EmailEntry"
                   Placeholder="Email address"
                   Keyboard="Email"
                   BackgroundColor="Transparent"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                   PlaceholderColor="Gray" />

            <!-- ── PASSWORD with eye toggle ── -->
            <Grid>
                <Entry x:Name="PasswordEntry"
                       Placeholder="Password"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                       PlaceholderColor="Gray"
                       Margin="0,0,0,0"
                       HorizontalOptions="Fill" />
                <!-- Eye label overlaid on the right side of the entry -->
                <Label x:Name="TogglePasswordBtn"
                       Text="Show"
                       FontSize="13"
                       TextColor="Gray"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       Padding="10,0"
                       Margin="0,0,5,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="TogglePassword_Clicked" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- ── ERROR ── -->
            <Label x:Name="ErrorLabel"
                   TextColor="Red" FontSize="13"
                   IsVisible="False"
                   HorizontalOptions="Center" />

            <!-- ── LOGIN BUTTON ── -->
            <Button x:Name="LoginButton"
                    Text="Log in"
                    Clicked="LoginButton_Clicked"
                    CornerRadius="12" FontAttributes="Bold"
                    HeightRequest="52" Margin="0,8,0,0" />

            <!-- ── BUSY ── -->
            <components:ModernLoader x:Name="BusyIndicator"
                                     IsRunning="False"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Margin="0,20" />


            </VerticalStackLayout>
        </ScrollView>

        <!-- ── CUSTOM FOOTER NAVIGATION (Absolute Bottom) ── -->
        <HorizontalStackLayout Grid.Row="0"
                               HorizontalOptions="Center" 
                               VerticalOptions="End"
                               Spacing="40" 
                               Padding="0,0,0,20">
            <Label Text="Login"
                   FontSize="16"
                   TextColor="#FF00FF"
                   FontAttributes="Bold">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LoginButton_Clicked" />
                </Label.GestureRecognizers>
            </Label>
            <Label Text="Register"
                   FontSize="16"
                   TextColor="Gray"
                   FontAttributes="Bold">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="RegisterButton_Clicked" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>
    </Grid>

</ContentPage>