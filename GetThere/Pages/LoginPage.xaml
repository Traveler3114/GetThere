<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    xmlns:localization="clr-namespace:GetThere.Localization"
    Title="{localization:Translate Login_Title}"
    Shell.NavBarIsVisible="False">

    <Grid>
        <components:AnimatedBackground />

        <ScrollView Padding="24,38,24,28">
            <VerticalStackLayout
                Spacing="24"
                HorizontalOptions="Center"
                MaximumWidthRequest="460">

                <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                    <Border
                        WidthRequest="112"
                        HeightRequest="112"
                        BackgroundColor="{AppThemeBinding Light={StaticResource AppSurfaceLight}, Dark={StaticResource AppSurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource AppBorderLight}, Dark={StaticResource AppBorderDark}}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="30" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.10" Radius="16" Offset="0,8" />
                        </Border.Shadow>
                        <Image
                            x:Name="LogoImage"
                            Source="logo.svg"
                            Margin="16"
                            Aspect="AspectFit" />
                    </Border>

                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label
                            Text="GetThere"
                            FontSize="30"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"
                            TextColor="{AppThemeBinding Light={StaticResource AppTextLight}, Dark={StaticResource AppTextDark}}" />
                        <Label
                            Text="One account for transit, tickets and mobility"
                            Style="{StaticResource MutedLabel}"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Border
                    x:Name="LoginCard"
                    Style="{StaticResource AppCard}"
                    Padding="22">
                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="7">
                            <Label
                                Text="{localization:Translate Login_EmailLabel}"
                                Style="{StaticResource SectionTitleLabel}"
                                FontSize="14" />
                            <Border Style="{StaticResource InputFrame}">
                                <Entry
                                    x:Name="EmailEntry"
                                    Placeholder="{localization:Translate Login_EmailPlaceholder}"
                                    Keyboard="Email"
                                    HeightRequest="50" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label
                                Text="{localization:Translate Login_PasswordLabel}"
                                Style="{StaticResource SectionTitleLabel}"
                                FontSize="14" />
                            <Border Style="{StaticResource InputFrame}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Entry
                                        x:Name="PasswordEntry"
                                        Placeholder="{localization:Translate Login_PasswordPlaceholder}"
                                        IsPassword="True"
                                        HeightRequest="50"
                                        VerticalOptions="Center" />
                                    <Label
                                        x:Name="TogglePasswordBtn"
                                        Grid.Column="1"
                                        Text="{localization:Translate Login_ShowPassword}"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource AppPrimary}"
                                        VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="TogglePassword_Clicked" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <Label
                            x:Name="ErrorLabel"
                            TextColor="{StaticResource AppDanger}"
                            FontSize="12"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            IsVisible="False" />

                        <HorizontalStackLayout Spacing="8" Padding="0,2">
                            <CheckBox
                                x:Name="RememberMeCheckbox"
                                Color="{StaticResource AppPrimary}"
                                IsChecked="False"
                                VerticalOptions="Center" />
                            <Label
                                Text="{localization:Translate Login_RememberMe}"
                                Style="{StaticResource MutedLabel}"
                                VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="RememberMeLabel_Tapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                        <Grid Margin="0,6,0,0">
                            <Button
                                x:Name="LoginButton"
                                Text="{localization:Translate Login_Button}"
                                Clicked="LoginButton_Clicked"
                                Style="{StaticResource PrimaryButton}" />

                            <Border
                                x:Name="LoadingState"
                                IsVisible="False"
                                HeightRequest="52"
                                BackgroundColor="{AppThemeBinding Light={StaticResource AppPrimarySoftLight}, Dark={StaticResource AppPrimarySoftDark}}"
                                StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Grid IsClippedToBounds="True">
                                    <Label
                                        x:Name="LoadingDotsLabel"
                                        Text="{localization:Translate Login_SigningIn}"
                                        FontSize="16"
                                        TextColor="{AppThemeBinding Light={StaticResource AppPrimaryDark}, Dark=#5EEAD4}"
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center" />
                                    <BoxView
                                        x:Name="ShimmerBox"
                                        WidthRequest="60"
                                        HorizontalOptions="Start"
                                        TranslationX="-60">
                                        <BoxView.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="Transparent" Offset="0" />
                                                <GradientStop Color="#80FFFFFF" Offset="0.5" />
                                                <GradientStop Color="Transparent" Offset="1" />
                                            </LinearGradientBrush>
                                        </BoxView.Background>
                                    </BoxView>
                                </Grid>
                            </Border>
                        </Grid>

                        <Label
                            Text="{localization:Translate Login_CreateAccount}"
                            TextColor="{StaticResource AppPrimary}"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            Margin="0,2,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="RegisterButton_Clicked" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
