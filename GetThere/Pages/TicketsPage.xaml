<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:GetThere.Components"
             xmlns:helpers="clr-namespace:GetThere.Helpers"
             x:Class="GetThere.Pages.TicketsPage"
             Title="My Tickets"
              BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#120D14}">

    <ContentPage.Resources>
        <helpers:StatusToColorConverter x:Key="StatusToColorConverter" />
        <DataTemplate x:Key="TicketRowTemplate">
            <Grid Padding="0,10" ColumnDefinitions="48,*,Auto" ColumnSpacing="12">
                <Border Grid.Column="0"
                        WidthRequest="48"
                        HeightRequest="48"
                        StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#ECECEC, Dark=#3A2A42}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Image Source="ticket_icon.png"
                           WidthRequest="24"
                           HeightRequest="24"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="{Binding TicketType}"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label Text="{Binding PurchasedAt, StringFormat='{0:dddd}'}"
                           FontSize="12"
                           TextColor="Gray" />
                </VerticalStackLayout>

                <Border Grid.Column="2"
                        VerticalOptions="Center"
                        Padding="12,8"
                        StrokeThickness="0"
                        BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="2">
                        <Label Text="{Binding Status}"
                               TextColor="White"
                               FontSize="12"
                               FontAttributes="Bold" />
                        <Label Text="›"
                               FontSize="16"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- ── DECORATIVE BACKGROUND CIRCLES ── -->
        <components:AnimatedBackground x:Name="AnimatedBg" />

        <!-- ── HEADER ── -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,*" Padding="16,18,16,0">
            <Label Grid.ColumnSpan="3"
                   Text="My Tickets"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            <Button x:Name="FilterBtn"
                    Grid.Column="2"
                    Style="{x:Null}"
                    Background="{x:Null}"
                    Text="Active ▾"
                    Clicked="OnShowFilterOptions"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#261A2B}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    CornerRadius="16"
                    HeightRequest="36"
                    Padding="20,0"
                    FontSize="14"
                    FontAttributes="Bold"
                    HorizontalOptions="End">
                <Button.Shadow>
                    <Shadow Brush="Transparent" Offset="0,2" Radius="5" Opacity="1" />
                </Button.Shadow>
            </Button>
        </Grid>

        <VerticalStackLayout Grid.Row="1" Margin="0,4,0,0" Spacing="6" HorizontalOptions="Center">
            <BoxView WidthRequest="70"
                     HeightRequest="3"
                     CornerRadius="2"
                     HorizontalOptions="Center"
                     BackgroundColor="{AppThemeBinding Light=#D1D1D6, Dark=#3A3A3C}" />
        </VerticalStackLayout>

        <Grid Grid.Row="2" Padding="16,8,16,100" BackgroundColor="Transparent" VerticalOptions="Start">
            <Border x:Name="TicketsContainer"
                    Padding="15"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                    StrokeThickness="0"
                    VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10" VerticalOptions="Start">
                    <ActivityIndicator x:Name="BusyIndicator"
                                       HeightRequest="40"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="#4CAF50" />

                    <VerticalStackLayout x:Name="TicketsRows"
                                         Spacing="0"
                                         VerticalOptions="Start" />

                    <VerticalStackLayout x:Name="TicketsEmptyState"
                                         IsVisible="False"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Padding="0,12"
                                         Spacing="10">
                        <Label x:Name="TicketsEmptyLabel"
                               Text="No tickets found"
                               FontSize="18"
                               TextColor="Gray"
                               HorizontalOptions="Center" />
                        <Label Text="Try changing your filter"
                               FontSize="14"
                               TextColor="Gray"
                               Opacity="1"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── CUSTOM FILTER BOTTOM SHEET ── -->
        <Grid x:Name="FilterBottomSheet" Grid.RowSpan="3" IsVisible="False" Opacity="0" ZIndex="1000" VerticalOptions="Fill" HorizontalOptions="Fill">
            <BoxView BackgroundColor="Black" Opacity="0.5">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHideFilterBottomSheet" />
                </BoxView.GestureRecognizers>
            </BoxView>
            <Grid VerticalOptions="End" InputTransparent="False">
                <Border x:Name="FilterContent" Margin="10,0,10,20" Padding="0" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}" 
                        TranslationY="600" HeightRequest="320" WidthRequest="360" HorizontalOptions="Center">
                    <Border.StrokeShape><RoundRectangle CornerRadius="28" /></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Offset="0,10" Radius="30" Opacity="0.4" /></Border.Shadow>
                    <VerticalStackLayout Padding="24" Spacing="12">
                        <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="Gray" Opacity="0.3" HorizontalOptions="Center" Margin="0,0,0,15" />
                        <Label Text="Filter Tickets" HorizontalOptions="Center" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Button Text="Active" Clicked="OnFilterOptionClicked" CommandParameter="Active" BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}" TextColor="{AppThemeBinding Light=Black, Dark=White}" CornerRadius="12" HeightRequest="50" FontSize="16" FontAttributes="Bold" />
                        <Button Text="Expired" Clicked="OnFilterOptionClicked" CommandParameter="Expired" BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}" TextColor="{AppThemeBinding Light=Black, Dark=White}" CornerRadius="12" HeightRequest="50" FontSize="16" FontAttributes="Bold" />
                        <Button Text="Used" Clicked="OnFilterOptionClicked" CommandParameter="Used" BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}" TextColor="{AppThemeBinding Light=Black, Dark=White}" CornerRadius="12" HeightRequest="50" FontSize="16" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>

    </Grid>
</ContentPage>
