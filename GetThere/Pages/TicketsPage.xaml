<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.TicketsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    xmlns:localization="clr-namespace:GetThere.Localization"
    Title="Tickets"
    BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#0F172A}"
    Shell.NavBarIsVisible="False">

    <Grid>
        <components:AnimatedBackground />

        <Grid RowDefinitions="Auto,*" Padding="20,32,20,96">
            <VerticalStackLayout Grid.Row="0" Spacing="4">
                <Label
                    Text="My Tickets"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Label
                    Text="Your active passes and transit tickets"
                    FontSize="15"
                    TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
            </VerticalStackLayout>

            <Grid Grid.Row="1" Margin="0,20,0,0">
                <!-- Loading State -->
                <VerticalStackLayout
                    x:Name="LoadingState"
                    Spacing="12"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="{DynamicResource Primary}" />
                    <Label
                        Text="Loading tickets..."
                        TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                </VerticalStackLayout>

                <!-- Empty State -->
                <VerticalStackLayout
                    x:Name="EmptyState"
                    IsVisible="False"
                    Spacing="12"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Padding="24">
                    <Label
                        Text="No tickets yet"
                        FontSize="22"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label
                        Text="Buy a ticket in the Shop tab to see it here."
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                        MaximumWidthRequest="360" />
                </VerticalStackLayout>

                <!-- Error & Account Required State -->
                <VerticalStackLayout
                    x:Name="ErrorState"
                    IsVisible="False"
                    Spacing="14"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Padding="24">
                    <Label
                        x:Name="ErrorTitleLabel"
                        Text="Could not load tickets"
                        FontSize="22"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label
                        x:Name="ErrorMessageLabel"
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                        MaximumWidthRequest="360" />
                    <Button
                        x:Name="RetryButton"
                        Text="Try again"
                        Clicked="OnRetryClicked"
                        BackgroundColor="{DynamicResource Primary}"
                        TextColor="White"
                        CornerRadius="18"
                        Padding="20,10" />
                </VerticalStackLayout>

                <!-- Tickets List -->
                <ScrollView x:Name="TicketsScrollView" IsVisible="False">
                    <VerticalStackLayout x:Name="TicketsList" Spacing="16" />
                </ScrollView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
