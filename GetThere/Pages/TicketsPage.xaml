<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:helpers="clr-namespace:GetThere.Helpers"
             xmlns:components="clr-namespace:GetThere.Components"
             x:Class="GetThere.Pages.TicketsPage"
             Title="My Tickets"
             BackgroundColor="#EDF1F7"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:StatusToColorConverter x:Key="StatusToColorConverter" />
        <DataTemplate x:Key="TicketRowTemplate">
            <Border Padding="12" Margin="0,0,0,10" BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,3" Radius="6" Opacity="0.12" />
                </Border.Shadow>
                
                <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                    <Border WidthRequest="40"
                            HeightRequest="40"
                            BackgroundColor="#F9FAFB"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Label Text="🎫"
                               FontSize="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                        <Label Text="{Binding TicketType}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1F2937"
                               LineBreakMode="TailTruncation" />
                        <Label Text="{Binding PurchasedAt, StringFormat='{0:ddd, dd MMM}'}"
                               FontSize="11"
                               TextColor="#6B7280" />
                    </VerticalStackLayout>

                    <Border Grid.Column="2"
                            VerticalOptions="Center"
                            Padding="12,6"
                            BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Label Text="{Binding Status}"
                               TextColor="White"
                               FontSize="12"
                               FontAttributes="Bold" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid>
        <components:AnimatedBackground />

        <!-- ── BACKGROUND (BLUE TOP) ── -->
        <Grid RowDefinitions="300, *">
            <BoxView Grid.Row="0" BackgroundColor="#4F46E5">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4F46E5" Offset="0" />
                        <GradientStop Color="#6366F1" Offset="1" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
        </Grid>

        <Grid RowDefinitions="Auto, *">
            <!-- ── HEADER ── -->
            <Grid x:Name="HeaderRow" Grid.Row="0" Margin="24,40,24,10" ColumnDefinitions="*, Auto" MaximumWidthRequest="600" HorizontalOptions="Fill">
                <Label Grid.Column="0" Text="My Tickets" FontSize="32" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                
                <Border x:Name="FilterBadge" Grid.Column="1" Padding="15,8" BackgroundColor="#D1FAE5" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="8" /></Border.Shadow>
                    <Label x:Name="FilterBtnLabel" Text="Active ▾" TextColor="#065F46" FontAttributes="Bold" FontSize="14">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnShowFilterOptions" />
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
            </Grid>

            <!-- ── TICKETS CONTENT (WHITE CARD OVERLAY) ── -->
            <Grid Grid.Row="1" Margin="0,10,0,0" HorizontalOptions="Fill">
                <Border x:Name="TicketsSurface" BackgroundColor="White" StrokeThickness="0" HorizontalOptions="Center" MaximumWidthRequest="1200">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="40,40,0,0" /></Border.StrokeShape>
                <ScrollView x:Name="MainScrollView" Scrolled="OnMainScrollViewScrolled" VerticalScrollBarVisibility="Never">
                    <VerticalStackLayout x:Name="TicketsContent" Padding="20,15,20,100" Spacing="16">
                        <BoxView x:Name="TopHandle" WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="#D8D8D8" HorizontalOptions="Center" />
                        
                        <VerticalStackLayout x:Name="MockTicketsSection" IsVisible="False" Spacing="20">
                            <Label Text="Session Tickets (Mock)" FontAttributes="Bold" FontSize="14" TextColor="#4B5563" />
                            
                            <Border Padding="15,10" BackgroundColor="#FEF3C7" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <Label Text="⚠️ MOCK TICKETS — NOT VALID FOR TRAVEL" TextColor="#92400E" FontSize="11" HorizontalOptions="Center" FontAttributes="Bold" />
                            </Border>

                            <VerticalStackLayout x:Name="MockTicketsRows" Spacing="0" />
                        </VerticalStackLayout>
                        
                        <Label x:Name="CurrentFilterSectionLabel" Text="Active Tickets" FontAttributes="Bold" FontSize="14" TextColor="#4B5563" Margin="0,10,0,0" />
                        
                        <!-- PREMIUM SKELETON LOADING STATE -->
                        <Grid x:Name="PremiumLoadingState" IsVisible="False" VerticalOptions="FillAndExpand">
                            <!-- Skeleton SVG -->
                            <Image Source="loading_tickets.svg" Aspect="AspectFill" InputTransparent="True" Opacity="0.8" />
                            
                            <!-- Shimmer Sweep (Full Screen) -->
                            <Grid IsClippedToBounds="True" InputTransparent="True">
                                <BoxView x:Name="ShimmerBox" WidthRequest="200" HorizontalOptions="Start" TranslationX="-300" Opacity="0.4">
                                    <BoxView.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="Transparent" Offset="0" />
                                            <GradientStop Color="#FFFFFF" Offset="0.5" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </LinearGradientBrush>
                                    </BoxView.Background>
                                    <BoxView.Rotation>15</BoxView.Rotation>
                                </BoxView>
                            </Grid>

                        </Grid>

                        <VerticalStackLayout x:Name="TicketsRows" Spacing="14" BindableLayout.ItemTemplate="{StaticResource TicketRowTemplate}" />

                        <VerticalStackLayout x:Name="TicketsEmptyState" IsVisible="False" Spacing="10" Margin="0,50">
                            <Label x:Name="TicketsEmptyLabel" Text="No items found" FontSize="18" TextColor="#4B5563" HorizontalOptions="Center" FontAttributes="Bold" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </Border>

            <!--  ── PREMIUM CUSTOM SCROLLBAR THUMB ──  -->
            <Border x:Name="CustomScrollThumb" 
                    WidthRequest="4" 
                    HeightRequest="40" 
                    BackgroundColor="#CBD5E1" 
                    HorizontalOptions="End" 
                    VerticalOptions="Start"
                    Margin="0,40,4,0" 
                    IsVisible="False"
                    ZIndex="1000">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="2" /></Border.StrokeShape>
            </Border>

            </Grid>
        </Grid>

        <!-- ── PREMIUM POPUP DROPDOWN (ANCHORED TO CONTENT) ── -->
        <Grid x:Name="FilterBottomSheet" Grid.RowSpan="2" IsVisible="False" Opacity="0">
            <BoxView BackgroundColor="#66000000">
                <BoxView.GestureRecognizers><TapGestureRecognizer Tapped="OnHideFilterBottomSheet" /></BoxView.GestureRecognizers>
            </BoxView>
            
            <!-- Centered container that matches header width -->
            <Grid MaximumWidthRequest="600" HorizontalOptions="Fill" VerticalOptions="Start" Margin="24,110,24,0">
                <Border x:Name="FilterContent" HorizontalOptions="End" 
                        Padding="1" StrokeThickness="0" BackgroundColor="White" 
                        WidthRequest="200" TranslationY="-20">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Offset="0,10" Radius="25" Opacity="0.15" /></Border.Shadow>
                    
                    <VerticalStackLayout Padding="8" Spacing="4">
                    <!-- Option: Active -->
                    <Border x:Name="ActiveOptionRow" Padding="12,10" StrokeThickness="0" BackgroundColor="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto">
                            <HorizontalStackLayout Spacing="10">
                                <Label x:Name="ActiveText" Text="Active" FontSize="16" TextColor="#374151" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label x:Name="ActiveCheckmark" Grid.Column="1" Text="✓" TextColor="#059669" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" IsVisible="False" />
                        </Grid>
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFilterOptionClicked" CommandParameter="Active" /></Border.GestureRecognizers>
                    </Border>
                    
                    <BoxView HeightRequest="1" BackgroundColor="#F3F4F6" Margin="12,2" />
                    
                    <!-- Option: Expired -->
                    <Border x:Name="ExpiredOptionRow" Padding="12,10" StrokeThickness="0" BackgroundColor="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto">
                            <Label x:Name="ExpiredText" Text="Expired" FontSize="16" TextColor="#374151" VerticalOptions="Center" />
                            <Label x:Name="ExpiredCheckmark" Grid.Column="1" Text="✓" TextColor="#059669" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" IsVisible="False" />
                        </Grid>
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFilterOptionClicked" CommandParameter="Expired" /></Border.GestureRecognizers>
                    </Border>
                    
                    <BoxView HeightRequest="1" BackgroundColor="#F3F4F6" Margin="12,2" />

                    <!-- Option: Used -->
                    <Border x:Name="UsedOptionRow" Padding="12,10" StrokeThickness="0" BackgroundColor="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto">
                            <Label x:Name="UsedText" Text="Used" FontSize="16" TextColor="#374151" VerticalOptions="Center" />
                            <Label x:Name="UsedCheckmark" Grid.Column="1" Text="✓" TextColor="#059669" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" IsVisible="False" />
                        </Grid>
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFilterOptionClicked" CommandParameter="Used" /></Border.GestureRecognizers>
                    </Border>
                </VerticalStackLayout>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
