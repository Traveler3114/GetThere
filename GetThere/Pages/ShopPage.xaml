<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.ShopPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    Title="Shop"
    BackgroundColor="#F8F9FA"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">
        <components:AnimatedBackground Grid.RowSpan="3" />

        <!--  Header  -->
        <Grid Grid.Row="0" Padding="16,18,16,0">
            <Label
                FontAttributes="Bold"
                FontSize="32"
                HorizontalTextAlignment="Center"
                Text="Shop"
                TextColor="Black" />
        </Grid>

        <!--  Country badge  -->
        <Grid Grid.Row="1" HorizontalOptions="Center">
            <Border
                x:Name="CountryBadge"
                Margin="16,10,16,0"
                Padding="12,6"
                BackgroundColor="#EBEBF0"
                HorizontalOptions="Start"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Label
                    x:Name="CountryBadgeLabel"
                    FontSize="13"
                    Text="All countries"
                    TextColor="#555" />
            </Border>
        </Grid>

        <!--  Operators list  -->
        <ScrollView Grid.Row="2" Padding="16,8,16,100">
            <VerticalStackLayout x:Name="ShopContent" HorizontalOptions="Center">

                <ActivityIndicator
                    x:Name="BusyIndicator"
                    HeightRequest="40"
                    IsRunning="False"
                    IsVisible="False"
                    Color="#1264AB" />

                <VerticalStackLayout x:Name="OperatorCards" Spacing="0" />

                <VerticalStackLayout x:Name="EmptyState" IsVisible="False">
                    <Label
                        Margin="0,40"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="No operators available for ticket purchase."
                        TextColor="Gray" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
