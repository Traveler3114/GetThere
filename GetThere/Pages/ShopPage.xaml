<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.ShopPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    xmlns:localization="clr-namespace:GetThere.Localization"
    Title="Shop"
    BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#0F172A}"
    Shell.NavBarIsVisible="False">

    <Grid>
        <components:AnimatedBackground />

        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" Padding="40">
            <Label Text="Shop" FontSize="32" FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            <Label x:Name="StatusLabel" Text="Coming Soon"
                   FontSize="20"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=Gray, Dark=#9CA3AF}" />
            <Label x:Name="DescriptionLabel"
                   Text="Ticket purchasing will be available once operator SDK adapters are implemented."
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                   MaximumWidthRequest="400" />
            <!-- TODO: Rebuild with ticketing SDK when adapters are implemented -->
        </VerticalStackLayout>
    </Grid>

</ContentPage>
