<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.ShopPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
    xmlns:components="clr-namespace:GetThere.Components"
    Title="Shop"
    BackgroundColor="#F8F9FA"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">
        <components:AnimatedBackground Grid.RowSpan="3" />

        <!--  Header  -->
        <Grid x:Name="PageHeaderGrid" Grid.Row="0" Padding="16,18,16,0">
            <Label
                FontAttributes="Bold"
                FontSize="32"
                HorizontalTextAlignment="Center"
                Text="Shop"
                TextColor="Black" />
        </Grid>

        <!--  Country badge  -->
        <Grid Grid.Row="1" HorizontalOptions="Center">
            <Border
                x:Name="CountryBadge"
                Margin="16,10,16,0"
                Padding="12,6"
                BackgroundColor="#EBEBF0"
                HorizontalOptions="Start"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Label
                    x:Name="CountryBadgeLabel"
                    FontSize="13"
                    Text="All countries"
                    TextColor="#555" />
            </Border>
        </Grid>

        <!--  Operators list  -->
        <Grid Grid.Row="2" HorizontalOptions="Fill">
            <ScrollView x:Name="MainScrollView" Scrolled="OnMainScrollViewScrolled" VerticalScrollBarVisibility="Never" Padding="16,8,16,100">
            <VerticalStackLayout x:Name="ShopContent" HorizontalOptions="Center" MaximumWidthRequest="1200">

                <!-- Loading state -->
                <Grid x:Name="LoadingState" IsVisible="False" VerticalOptions="FillAndExpand">
                    <!-- Skeleton SVG -->
                    <Image Source="loading_shop.svg" Aspect="AspectFill" InputTransparent="True" Opacity="0.8" />
                    
                    <!-- Shimmer Sweep -->
                    <Grid IsClippedToBounds="True" InputTransparent="True">
                        <BoxView x:Name="ShimmerBox" WidthRequest="250" HorizontalOptions="Start" TranslationX="-400" Opacity="0.3">
                            <BoxView.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0" />
                                    <GradientStop Color="#FFFFFF" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </BoxView.Background>
                            <BoxView.Rotation>20</BoxView.Rotation>
                        </BoxView>
                    </Grid>
                </Grid>

                <VerticalStackLayout x:Name="OperatorCards" Spacing="0" />

                <VerticalStackLayout x:Name="EmptyState" IsVisible="False">
                    <Label
                        Margin="0,40"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="No operators available for ticket purchase."
                        TextColor="Gray" />
                </VerticalStackLayout>

            </VerticalStackLayout>
            </ScrollView>

            <!--  ── CUSTOM SCROLLBAR THUMB ──  -->
            <Border x:Name="CustomScrollThumb" 
                    WidthRequest="4" 
                    HeightRequest="40" 
                    BackgroundColor="#CBD5E1" 
                    HorizontalOptions="End" 
                    VerticalOptions="Start"
                    Margin="0,0,4,0" 
                    IsVisible="False"
                    ZIndex="1000">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="2" /></Border.StrokeShape>
            </Border>

        </Grid>
    </Grid>
</ContentPage>
