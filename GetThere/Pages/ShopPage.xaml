<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GetThere.Pages.ShopPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GetThere.Components"
    Title="Shop"
    BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#120D14}">

    <Grid RowDefinitions="Auto,Auto,*">

        <components:AnimatedBackground Grid.RowSpan="3" />

        <!--  Header  -->
        <Grid Grid.Row="0" Padding="16,18,16,0">
            <Label
                FontAttributes="Bold"
                FontSize="28"
                HorizontalTextAlignment="Center"
                Text="Shop"
                TextColor="{AppThemeBinding Light=Black, Dark=White}" />
        </Grid>

        <!--  Country badge  -->
        <Border
            x:Name="CountryBadge"
            Grid.Row="1"
            Margin="16,10,16,0"
            Padding="12,6"
            BackgroundColor="{AppThemeBinding Light=#EBEBF0, Dark=#2C2C2E}"
            HorizontalOptions="Start"
            StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Label
                x:Name="CountryBadgeLabel"
                FontSize="13"
                Text="All countries"
                TextColor="{AppThemeBinding Light=#555, Dark=#AAA}" />
        </Border>

        <!--  Operators list  -->
        <ScrollView Grid.Row="2" Padding="16,8,16,100">
            <VerticalStackLayout>

                <ActivityIndicator
                    x:Name="BusyIndicator"
                    HeightRequest="40"
                    IsRunning="False"
                    IsVisible="False"
                    Color="#1264AB" />

                <VerticalStackLayout x:Name="OperatorCards" Spacing="0" />

                <VerticalStackLayout x:Name="EmptyState" IsVisible="False">
                    <Label
                        Margin="0,40"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="No operators available for ticket purchase."
                        TextColor="Gray" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
