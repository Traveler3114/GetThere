<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
              xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:vm="clr-namespace:GetThere.ViewModels"
              xmlns:components="clr-namespace:GetThere.Components"
              x:DataType="vm:MapViewModel"
              x:Class="GetThere.Pages.MapPage"
              BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#0F172A}"
              Shell.NavBarIsVisible="False">

    <Grid>
        <components:AnimatedBackground />
        <WebView Source="{Binding MapUrl}" />
    </Grid>

</ContentPage>
