<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GetThere.Pages.MapPage"
             Title="MapPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        
        <Grid Grid.Row="0">
            <!-- Map WebView -->
            <HybridWebView x:Name="MapWebView"
                         HybridRoot="HybridWebViewRoot"
                         HorizontalOptions="Fill"
                         VerticalOptions="Fill" />
        </Grid>


        <Button
                Grid.Row="1"
                x:Name="SimulateLocationBtn"
                Text="Stimuliraj GPS pokret (5km)"
                Clicked="OnSimulateLocationClicked"
                HorizontalOptions="Fill"
                BackgroundColor="#2196F3"
                TextColor="White"
                Margin="10" />




        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay"
              Grid.Row="0"
              IsVisible="True"
              BackgroundColor="#80000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="10">
                <ActivityIndicator
                    IsRunning="True"
                    Color="White"
                    HeightRequest="50"
                    WidthRequest="50" />
                <Label
                    Text="Loading map..."
                    TextColor="White"
                    FontSize="16"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
        
    </Grid>
    

</ContentPage>