<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:GetThere.Components"
             x:Class="GetThere.Pages.MapPage"
             Title="Map">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <components:AnimatedBackground Grid.RowSpan="2" />

        <Grid Grid.Row="0">
            <!-- Map WebView -->
            <WebView x:Name="MapWebView"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill" />
            
            <!-- Loading Overlay -->
            <Grid x:Name="LoadingOverlay"
                  IsVisible="True"
                  BackgroundColor="#80000000"
                  HorizontalOptions="Fill"
                  VerticalOptions="Fill">
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="10">
                    <components:ModernLoader 
                        IsRunning="True"
                        HeightRequest="60" WidthRequest="60" />
                    <Label
                        Text="Loading map..."
                        TextColor="White"
                        FontSize="16"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <Button
                Grid.Row="1"
                x:Name="SimulateLocationBtn"
                Text="Stimuliraj GPS pokret (5km)"
                Clicked="OnSimulateLocationClicked"
                HorizontalOptions="Fill"
                BackgroundColor="#2196F3"
                TextColor="White"
                Margin="10" />

    </Grid>

</ContentPage>