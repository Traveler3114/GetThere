<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:GetThere.Components"
             xmlns:behaviors="clr-namespace:GetThere.Behaviors"
             x:Class="GetThere.Pages.MapPage"
             Title="MapPage">

    <Grid RowDefinitions="*,Auto">
        <!-- Animated Background -->
        <components:AnimatedBackground x:Name="AnimatedBg" Grid.RowSpan="2" />

        <!-- Map WebView -->
        <WebView x:Name="MapWebView"
                 Grid.Row="0"
                 Source="HybridWebViewRoot/index.html"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill" />

        <Border Grid.Row="1"
                Margin="20,10,20,120"
                Padding="0"
                HeightRequest="56"
                BackgroundColor="White"
                StrokeThickness="1"
                Stroke="#E0E0E0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28" />
            </Border.StrokeShape>
            <Button x:Name="SimulateLocationBtn"
                    Text="Stimuliraj GPS pokret (5km)"
                    Clicked="OnSimulateLocationClicked"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#444444, Dark=White}"
                    FontSize="14"
                    FontAttributes="Bold"
                    Padding="20,0" />
        </Border>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay"
              Grid.Row="0"
              IsVisible="True"
              BackgroundColor="#80000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="10">
                <ActivityIndicator
                    IsRunning="True"
                    Color="White"
                    HeightRequest="50"
                    WidthRequest="50" />
                <Label
                    Text="Loading map..."
                    TextColor="White"
                    FontSize="16"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- ── CUSTOM BOTTOM BAR ── -->
        <components:CustomBottomBar Grid.RowSpan="2" VerticalOptions="End" />
    </Grid>
</ContentPage>