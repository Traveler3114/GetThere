{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TransitInfoDB;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "FeedPolling": {
    "IntervalMinutes": 60,
    "MaxConsecutiveFailuresBeforeDeactivate": 10
  },
  "RealtimePolling": {
    "IntervalSeconds": 30,
    "MaxConsecutiveFailuresBeforeDeactivate": 10
  },
  "Reconciliation": {
    "AutoMergeNameThreshold": 0.90,
    "AutoMergeDistanceMeters": 100,
    "ManualReviewNameThreshold": 0.70,
    "ManualReviewDistanceMeters": 300
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "TransitInfoAPI": "Information",
      "Microsoft.Hosting.Lifetime": "Warning",
      "System.Net.Http": "None"
    }
  },
  "CustomFeedImport": {
    "StopCountDropThreshold": 0.90,
    "RouteCountDropThreshold": 0.90,
    "MaxVersionRetention": 2
  },
  "PlaceMatching": {
    "MaxDistanceMeters": 50000,
    "DefaultCountryId": 2
  },
  "AllowedHosts": "*"
}
