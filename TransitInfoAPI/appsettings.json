{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TransitInfoDB;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "FeedPolling": {
    "IntervalMinutes": 60,
    "MaxConcurrentImports": 3
  },
  "Reconciliation": {
    "AutoMergeNameThreshold": 0.90,
    "AutoMergeDistanceMeters": 30,
    "ManualReviewNameThreshold": 0.70,
    "ManualReviewDistanceMeters": 50
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "TransitInfoAPI": "Information",
      "Microsoft.Hosting.Lifetime": "Warning",
      "System.Net.Http": "None"
    }
  },
  "AllowedHosts": "*"
}
