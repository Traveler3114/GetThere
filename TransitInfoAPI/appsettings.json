{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TransitInfoDB;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "FeedPolling": {
    "IntervalMinutes": 60,
    "MaxConsecutiveFailuresBeforeDeactivate": 10
  },
  "RealtimePolling": {
    "IntervalSeconds": 30,
    "MaxConsecutiveFailuresBeforeDeactivate": 10
  },
  "Reconciliation": {
    "AutoMergeNameThreshold": 0.90,
    "AutoMergeDistanceMeters": 100,
    "ManualReviewNameThreshold": 0.70,
    "ManualReviewDistanceMeters": 300
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      },
      "Https": {
        "Url": "https://0.0.0.0:5001"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "TransitInfoAPI": "Information",
      "Microsoft.Hosting.Lifetime": "Warning",
      "System.Net.Http": "None"
    }
  },
  "Jwt": {
    "Key": "CHANGE-ME",
    "Issuer": "TransitInfoAPI",
    "Audience": "TransitInfoApp",
    "ExpiryMinutes": 15,
    "RefreshTokenDays": 1,
    "RefreshTokenDaysRememberMe": 30
  },
  "MobilityPolling": {
    "IntervalSeconds": 120,
    "MaxConsecutiveFailuresBeforeDeactivate": 10,
    "InitialDelaySeconds": 15
  },
  "PlaceMatching": {
    "MaxDistanceMeters": 50000,
    "DefaultCountryId": 2
  },
  "AllowedHosts": "*",
  // Credentials are generated on first run.
  // See docs/secrets-rotation.md for management.
}