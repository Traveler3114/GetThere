{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=GetThereDB;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "OtpConfigSource": "Database",
  "OtpConfigValidation": {
    "EnableDualPathComparison": "false",
    "FailOnMismatch": "true"
  },
  "Gtfs": {
    "ZipUrl": "https://www.hzpp.hr/GTFS_files.zip"
  },
  "Scrape": {
    "IntervalSeconds": "30",
    "RequestDelaySeconds": "0.3"
  },
  "Otp": {
    "AutoStart": "true",
    "JavaExecutable": "",
    "JarPath": "otp-shaded-2.9.0.jar",
    "Arguments": "",
    "WorkingDirectory": ""
  },
  "OperatorSource": {
    "ApiBaseUrl": "https://localhost:7230",
    "OtpFeedsPath": "/operator/otp-feeds",
    "UpdaterFrequency": "PT30S",
    "HzppFallbackRealtimeUrl": "http://127.0.0.1:5000/rt/hzpp",
    "TransitModelTimeZone": "Europe/Zagreb",
    "StrictReachabilityChecks": "false"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "OpenTripPlannerAPI": "Information",
      "Microsoft.Hosting.Lifetime": "Warning",
      "System.Net.Http": "None"
    }
  },
  "AllowedHosts": "*"
}
